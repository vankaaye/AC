---
/**
 * Layout.astro
 * ------------------------------------------------------------------
 * Core structural layout for astrocare.com.au.
 *
 * Accessibility framework (WCAG 2.2 AAA targets):
 *  - Skip link as the very first focusable element.
 *  - Semantic landmarks: <header>, <nav>, <main id="main">, <footer>.
 *  - Body text 20px+; every size in rem so the Accessibility Panel
 *    can scale the interface to 200%.
 *  - All interactive targets >= 56x56px, click-only interactions,
 *    no hover-dependent menus, no carousels.
 *  - Persistent, non-blocking "Sarah" help widget with one-click
 *    call and callback actions.
 * ------------------------------------------------------------------
 */
import AccessibilityToggle from '../components/AccessibilityToggle.astro';
import ChatWidget from '../components/ChatWidget.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Astro Care — Friendly Aged Care & Help at Home | Australia',
  description = 'Astro Care Group helps Australian seniors live happily and safely at home — Home Care Packages (HCP), Commonwealth Home Support (CHSP), clinical care, social support, domestic assistance and meal preparation.',
} = Astro.props;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=Nunito:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to main content</a>

    <!-- ============ OVERSIZED STICKY HEADER ============ -->
    <header
      class="sticky top-0 z-[110] border-b-4 hc-border"
      style="background: var(--bg-card); border-color: var(--line);"
    >
      <div class="mx-auto flex w-[min(1360px,100%-1rem)] flex-wrap items-center justify-between gap-x-4 gap-y-1 py-2 md:py-3">
        <!-- Brand: logo mark + wordmark (also mirrored in the browser tab favicon) -->
        <a href="/" class="flex min-h-12 items-center gap-2 md:min-h-14 md:gap-3" aria-label="Astro Care — home">
          <svg class="h-10 w-10 md:h-14 md:w-14" viewBox="0 0 48 48" fill="none" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="#2F6B51"></circle><path d="M13 38 L24 12 L35 38" fill="none" stroke="#FFC24B" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"></path><path d="M16.5 29.5 h3.3 l1.65 -3.9 l2.4 7.8 l2.1 -5.1 l1.2 1.2 h4.35" fill="none" stroke="#FFFFFF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          <span class="font-[900] text-2xl md:text-3xl" style="font-family: var(--font-head); color: var(--euca);">
            Astro <em class="not-italic" style="color: var(--sun-deep);">Care</em>
          </span>
        </a>

        <!-- One-click call, always visible (compact on phones) -->
        <a href="tel:+611800278762" class="btn-call hc-border order-2 !min-h-12 !px-4 !py-2 !text-lg md:order-3 md:!min-h-14 md:!px-7 md:!py-4 md:!text-xl">
          <svg class="h-6 w-6 md:h-8 md:w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span class="flex flex-col text-left leading-tight">
            <small class="hidden text-sm font-bold opacity-95 md:inline">Call Us Now — Free</small>
            1800 ASTRO
          </span>
        </a>

        <!-- Primary navigation: plain, always-visible links. No dropdowns. -->
        <nav aria-label="Main menu" class="order-3 -mx-1 flex w-full flex-wrap gap-0 md:order-2 md:w-auto md:gap-1">
          {
            [
              ['/#services', 'Services'],
              ['/#funding', 'Funding'],
              ['/#pricing', 'Fees'],
              ['/#contact', 'Contact'],
            ].map(([href, label]) => (
              <a
                href={href}
                class="flex min-h-11 items-center rounded-xl px-2.5 text-base font-extrabold transition-colors hover:bg-[var(--euca-soft)] hover:text-[var(--euca)] md:min-h-14 md:rounded-2xl md:px-4 md:text-xl"
                style="font-family: var(--font-head);"
              >
                {label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <!-- ============ FOOTER ============ -->
    <footer class="mt-0 pt-14 pb-8" style="background: var(--euca-deep); color: #fff;">
      <div class="mx-auto grid w-[min(1220px,100%-2.5rem)] gap-9 border-b-2 border-white/25 pb-9 md:grid-cols-3">
        <div>
          <a href="/" class="flex min-h-14 items-center gap-3" aria-label="Astro Care — back to top">
            <svg class="h-12 w-12" viewBox="0 0 48 48" fill="none" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="#FFFFFF"></circle><path d="M13 38 L24 12 L35 38" fill="none" stroke="#2F6B51" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"></path><path d="M16.5 29.5 h3.3 l1.65 -3.9 l2.4 7.8 l2.1 -5.1 l1.2 1.2 h4.35" fill="none" stroke="#E2A93B" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            <span class="font-[900] text-2xl" style="font-family: var(--font-head);">Astro <em class="not-italic" style="color: var(--sun);">Care</em></span>
          </a>
          <p class="mt-3 font-extrabold text-xl" style="font-family: var(--font-head); color: var(--sun);">Where every day shines.</p>
        </div>
        <div class="flex flex-col gap-2 text-xl">
          <h3 class="text-xl" style="color: var(--sun);">Talk to us</h3>
          <a class="flex min-h-14 items-center underline-offset-4 hover:underline" href="tel:+611800278762">1800 ASTRO (278 762)</a>
          <a class="flex min-h-14 items-center underline-offset-4 hover:underline" href="mailto:info@astrocare.com.au">info@astrocare.com.au</a>
          <span>Mon–Fri 8am–6pm · Sat 9am–4pm</span>
        </div>
        <nav class="flex flex-col gap-2 text-xl" aria-label="Footer links">
          <h3 class="text-xl" style="color: var(--sun);">Find your way</h3>
          <a class="flex min-h-14 items-center underline-offset-4 hover:underline" href="#services">Our Services</a>
          <a class="flex min-h-14 items-center underline-offset-4 hover:underline" href="#funding">Funding Help</a>
          <a class="flex min-h-14 items-center underline-offset-4 hover:underline" href="#pricing">Fees &amp; Pricing</a>
          <a class="flex min-h-14 items-center underline-offset-4 hover:underline" href="#contact">Contact</a>
        </nav>
      </div>
      <div class="mx-auto flex w-[min(1220px,100%-2.5rem)] flex-wrap justify-between gap-3 pt-6 text-base text-white/80">
        <p>© 2026 Astro Care Group Pty Ltd · ABN 99 700 192 981</p>
        <p>We acknowledge the Traditional Owners of the lands on which we care, and pay our respects to Elders past and present.</p>
      </div>
    </footer>

    <!-- ============ PERSISTENT "SARAH" HELP WIDGET ============ -->
    <!-- Non-blocking sticky bar: always reachable, never covers content
         (the page reserves space via the body padding below). -->
    <div
      class="fixed bottom-0 left-0 right-0 z-[115] border-t-4 hc-border"
      style="background: var(--bg-card); border-color: var(--sun); box-shadow: 0 -8px 30px rgba(30,40,35,0.15);"
      role="complementary"
      aria-label="Talk to us"
    >
      <div class="mx-auto flex w-[min(1220px,100%-1rem)] items-center gap-3 py-2 md:gap-5 md:py-3">
        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border-4 md:h-16 md:w-16" style="background: var(--euca); border-color: var(--sun);" aria-hidden="true">
          <svg class="h-9 w-9 md:h-11 md:w-11" viewBox="0 0 48 48" fill="none" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="#2F6B51"></circle><path d="M13 38 L24 12 L35 38" fill="none" stroke="#FFC24B" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"></path><path d="M16.5 29.5 h3.3 l1.65 -3.9 l2.4 7.8 l2.1 -5.1 l1.2 1.2 h4.35" fill="none" stroke="#FFFFFF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
        </span>
        <p class="hidden text-xl leading-snug lg:block lg:flex-1">
          <strong style="font-family: var(--font-head);">Questions? We're here to help.</strong><br />
          <span style="color: var(--tx-soft);">Free call, friendly answers — no obligation ever.</span>
        </p>
        <div class="flex flex-1 flex-wrap justify-end gap-2 md:gap-3">
          <a href="tel:+611800278762" class="btn-call hc-border flex-1 !min-h-12 !px-3 !text-base sm:flex-none md:!min-h-14 md:!px-6 md:!text-xl">
            <span class="md:hidden">Call us — free</span>
            <span class="hidden md:inline">Call 1800 ASTRO — free</span>
          </a>
          <button id="openChat" class="btn-sun hc-border flex-1 !min-h-12 !px-3 !text-base sm:flex-none md:!min-h-14 md:!px-6 md:!text-xl" aria-haspopup="dialog" aria-expanded="false" aria-controls="chatPanel">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Chat with us
          </button>
        </div>
      </div>
    </div>
    <!-- Reserve room so the sticky widget never obscures page content -->
    <div aria-hidden="true" class="h-20 md:h-24"></div>

    <ChatWidget />
    <AccessibilityToggle />

    <script is:inline>
      /* Smooth in-page scrolling that respects the sticky header height,
         and moves focus so screen-reader users land where they clicked to. */
      document.querySelectorAll('a[href^="#"]').forEach(function (a) {
        a.addEventListener('click', function (e) {
          var target = document.querySelector(a.getAttribute('href'));
          if (target) {
            e.preventDefault();
            var header = document.querySelector('header');
            var offset = (header ? header.offsetHeight : 0) + 14;
            window.scrollTo({ top: target.offsetTop - offset, behavior: 'smooth' });
            target.setAttribute('tabindex', '-1');
            target.focus({ preventScroll: true });
          }
        });
      });
    </script>
  </body>
</html>
