---
/**
 * Layout.astro — "AU Modern" (design v2)
 * ------------------------------------------------------------------
 * Slim glassy sticky header (hides on scroll down, returns on scroll
 * up), modern navy footer with Acknowledgement of Country, floating
 * chat button. Accessibility framework retained: skip link, semantic
 * landmarks, palette + text scaling via CSS custom properties, and
 * the Accessibility Panel.
 * ------------------------------------------------------------------
 */
import AccessibilityToggle from '../components/AccessibilityToggle.astro';
import ChatWidget from '../components/ChatWidget.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Astro Care — Aged Care & Help at Home | Australia',
  description = 'Astro Care Group helps older Australians live well at home — Support at Home, Home Care Packages, nursing, social support, domestic assistance and meals. Australian owned & run.',
} = Astro.props;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@500;600;700;800&family=Instrument+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <a class="skip-link" href="#main">Skip to main content</a>

    <!-- ============ SLIM STICKY HEADER ============ -->
    <header
      id="siteHeader"
      class="fixed inset-x-0 top-0 z-[110] transition-transform duration-300"
      style="background: rgba(255,255,255,0.86); backdrop-filter: saturate(160%) blur(14px); -webkit-backdrop-filter: saturate(160%) blur(14px); border-bottom: 1px solid var(--line);"
    >
      <div class="mx-auto flex h-14 w-[min(1200px,100%-2rem)] items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-2.5" aria-label="Astro Care — home">
          <svg class="h-8 w-8" viewBox="0 0 48 48" fill="none" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="#0C6291"></circle><path d="M13 38 L24 12 L35 38" fill="none" stroke="#FFFFFF" opacity="0.95" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"></path><path d="M16.5 29.5 h3.3 l1.65 -3.9 l2.4 7.8 l2.1 -5.1 l1.2 1.2 h4.35" fill="none" stroke="#FFFFFF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          <span class="text-[1.05rem] font-bold tracking-tight" style="font-family: var(--font-head); color: var(--tx);">
            Astro <span style="color: var(--euca);">Care</span>
          </span>
        </a>

        <nav aria-label="Main menu" class="hidden items-center gap-0.5 sm:flex">
          {
            [
              ['/#services', 'Services'],
              ['/#how', 'How it works'],
              ['/#funding', 'Funding'],
              ['/#pricing', 'Fees'],
              ['/#contact', 'Contact'],
            ].map(([href, label]) => (
              <a
                href={href}
                class="flex min-h-9 items-center rounded-full px-3 text-[0.88rem] font-semibold transition-colors hover:bg-[var(--euca-soft)] hover:text-[var(--euca)]"
                style="color: var(--tx-soft);"
              >
                {label}
              </a>
            ))
          }
        </nav>

        <div class="flex items-center gap-2">
          <a href="tel:+611800278762" class="flex min-h-9 items-center gap-1.5 rounded-full border px-3.5 text-[0.88rem] font-bold" style="border-color: var(--line); color: var(--euca);">
            <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            1800 ASTRO
          </a>
          <button
            id="menuBtn"
            class="flex h-9 w-9 items-center justify-center rounded-full border sm:hidden"
            style="border-color: var(--line); color: var(--tx);"
            aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobileMenu" class="hidden border-t sm:hidden" style="border-color: var(--line); background: rgba(255,255,255,0.97);">
        <nav aria-label="Mobile menu" class="mx-auto grid w-[min(1280px,100%-2rem)] gap-1 py-3">
          {
            [
              ['/#services', 'Services'],
              ['/#how', 'How it works'],
              ['/#funding', 'Funding'],
              ['/#pricing', 'Fees'],
              ['/#contact', 'Contact'],
            ].map(([href, label]) => (
              <a href={href} class="flex min-h-12 items-center rounded-xl px-3 text-lg font-semibold" style="color: var(--tx);">
                {label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <!-- ============ FOOTER ============ -->
    <footer class="pt-16 pb-10" style="background: #10222B; color: #fff;">
      <div class="mx-auto grid w-[min(1280px,100%-2.5rem)] gap-10 border-b border-white/15 pb-10 md:grid-cols-[1.4fr_1fr_1fr]">
        <div>
          <a href="/" class="flex items-center gap-2.5" aria-label="Astro Care — back to top">
            <svg class="h-10 w-10" viewBox="0 0 48 48" fill="none" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="#FFFFFF"></circle><path d="M13 38 L24 12 L35 38" fill="none" stroke="#0C6291" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"></path><path d="M16.5 29.5 h3.3 l1.65 -3.9 l2.4 7.8 l2.1 -5.1 l1.2 1.2 h4.35" fill="none" stroke="#0C6291" stroke-width="2.4" opacity="0.55" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            <span class="text-xl font-extrabold" style="font-family: var(--font-head);">Astro Care</span>
          </a>
          <p class="mt-4 max-w-sm text-[0.98rem] leading-relaxed text-white/70">
            Australian owned &amp; run. We help older Australians live well in their own homes —
            with nursing, everyday help and genuine company.
          </p>
        </div>
        <div class="flex flex-col gap-1 text-[0.98rem]">
          <h3 class="mb-2 text-sm font-bold uppercase tracking-wider text-white/50">Talk to us</h3>
          <a class="flex min-h-10 items-center text-white/85 underline-offset-4 hover:underline" href="tel:+611800278762">1800 ASTRO (1800 278 762)</a>
          <a class="flex min-h-10 items-center text-white/85 underline-offset-4 hover:underline" href="mailto:info@astrocare.com.au">info@astrocare.com.au</a>
          <span class="text-white/60">Mon–Fri 8am–6pm · Sat 9am–4pm</span>
        </div>
        <nav class="flex flex-col gap-1 text-[0.98rem]" aria-label="Footer links">
          <h3 class="mb-2 text-sm font-bold uppercase tracking-wider text-white/50">Explore</h3>
          <a class="flex min-h-10 items-center text-white/85 underline-offset-4 hover:underline" href="/#services">Our services</a>
          <a class="flex min-h-10 items-center text-white/85 underline-offset-4 hover:underline" href="/#funding">Funding help</a>
          <a class="flex min-h-10 items-center text-white/85 underline-offset-4 hover:underline" href="/#pricing">Fees &amp; pricing</a>
          <a class="flex min-h-10 items-center text-white/85 underline-offset-4 hover:underline" href="/#contact">Contact</a>
        </nav>
      </div>
      <div class="mx-auto flex w-[min(1280px,100%-2.5rem)] flex-wrap justify-between gap-3 pt-6 text-sm text-white/55">
        <p>© 2026 Astro Care Group Pty Ltd · ABN 99 700 192 981</p>
        <p class="max-w-xl">We acknowledge the Traditional Owners of the lands on which we care, and pay our respects to Elders past and present.</p>
      </div>
    </footer>

    <!-- Floating chat button -->
    <button
      id="openChat"
      class="fixed bottom-5 right-5 z-[125] flex items-center gap-2 rounded-full px-5 py-3 text-[0.98rem] font-bold text-white shadow-xl transition-transform hover:-translate-y-0.5"
      style="background: var(--euca); box-shadow: 0 10px 30px rgba(12,98,145,0.4); font-family: var(--font-head);"
      aria-haspopup="dialog" aria-expanded="false" aria-controls="chatPanel"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      Chat with us
    </button>

    <ChatWidget />
    <AccessibilityToggle />

    <script is:inline>
      /* Header: hide on scroll down, show on scroll up. */
      (function () {
        var header = document.getElementById('siteHeader');
        var lastY = 0;
        window.addEventListener('scroll', function () {
          var y = window.scrollY;
          if (y > 120 && y > lastY) header.style.transform = 'translateY(-100%)';
          else header.style.transform = '';
          lastY = y;
        }, { passive: true });
      })();

      /* Mobile menu toggle. */
      (function () {
        var btn = document.getElementById('menuBtn');
        var menu = document.getElementById('mobileMenu');
        if (!btn || !menu) return;
        btn.addEventListener('click', function () {
          var open = menu.classList.toggle('hidden') === false;
          btn.setAttribute('aria-expanded', String(open));
        });
        menu.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', function () { menu.classList.add('hidden'); btn.setAttribute('aria-expanded', 'false'); });
        });
      })();

      /* Smooth in-page scrolling with header offset. */
      document.querySelectorAll('a[href*="#"]').forEach(function (a) {
        a.addEventListener('click', function (e) {
          var hash = a.getAttribute('href').split('#')[1];
          if (!hash) return;
          var target = document.getElementById(hash);
          if (target) {
            e.preventDefault();
            window.scrollTo({ top: target.offsetTop - 72, behavior: 'smooth' });
            target.setAttribute('tabindex', '-1');
            target.focus({ preventScroll: true });
          }
        });
      });

      /* Scroll-reveal: any element with .rv fades up when it enters view. */
      (function () {
        if (!('IntersectionObserver' in window)) {
          document.querySelectorAll('.rv').forEach(function (el) { el.classList.add('in'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
        document.querySelectorAll('.rv').forEach(function (el) { io.observe(el); });
      })();

      /* Ambient videos: play only in view, respect reduced motion. */
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var vids = document.querySelectorAll('video[data-ambient]');
        if (!vids.length) return;
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            var v = e.target;
            if (e.isIntersecting) { v.play().catch(function () {}); }
            else { v.pause(); }
          });
        }, { threshold: 0.2 });
        vids.forEach(function (v) { io.observe(v); });
      })();
    </script>
  </body>
</html>
