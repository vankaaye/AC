---
import '../styles/global.css';
const services = [
  ['Clinical & nursing care', 'Wound care, medication, health checks & recovery — by registered nurses.', '/media/poster-clinical.jpg'],
  ['Personal care', 'A gentle hand with showering, dressing and getting ready for the day.', '/media/loop-personal.jpg'],
  ['Allied health & therapy', 'Physio, OT and exercise to keep you strong, steady and moving well.', '/media/loop-allied.jpg'],
  ['Domestic assistance', 'Cleaning, laundry and light gardening — home kept safe and lovely.', '/media/poster-domestic.jpg'],
  ['Meal preparation', 'Fresh meals cooked your way, with good company while they’re made.', '/media/poster-meals.jpg'],
  ['Social support & company', 'Friendly visits, outings and someone to share a cuppa and a laugh.', '/media/poster-social.jpg'],
  ['Transport & getting out', 'Lifts to appointments, the shops or a favourite spot — company along the way.', '/media/loop-transport.jpg'],
  ['Respite & overnight care', 'A trusted hand so family carers can rest — hours or overnight.', '/media/loop-respite.jpg'],
];
const steps = [
  ['01', 'Say hello', 'Chat with us online or leave your number — no obligation.'],
  ['02', 'We sort the funding', 'We guide you through My Aged Care and handle the paperwork with you.'],
  ['03', 'Care begins at home', 'Your support workers arrive when you want them — and it flexes as needs change.'],
];
const funding = [
  ['Support at Home', 'Most people start here', 'The government program for care at home — funded on your assessed needs, from about $11,000 to $78,000 a year.'],
  ['CHSP', 'Entry-level help', 'A little help — cleaning, meals or transport — with a small contribution per service.'],
  ['Private care', 'No waiting', 'Start straight away from $65/hour and switch to government funding once approved.'],
];
const faqs = [
  ['Who is eligible for funded care?', 'Generally Australians 65+ (50+ for First Nations people) who need help to keep living at home. A free My Aged Care assessment confirms it — we help you arrange it.'],
  ['How much will it cost us?', 'The government pays the large majority for most people. Our fees are 15% care + 10% package management, under the caps, all published.'],
  ['How quickly can care start?', 'Privately within days; government-funded depends on the queue. Many start privately and switch when funding is approved.'],
  ['Where do you operate?', 'Right across Melbourne — inner suburbs to the outer ring.'],
];
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><meta name="robots" content="noindex" />
    <title>Astro Care — Editorial concept (full)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      :root { --e-bg:#f4f1ec; --e-paper:#fbfaf7; --e-ink:#2b2c2a; --e-mut:#6f7069; --e-line:#dcd7ce; --e-accent:#3c4246; --e-gold:#a8813f; }
      * { box-sizing:border-box; }
      body { margin:0; background:var(--e-bg); color:var(--e-ink); font-family:'Instrument Sans',sans-serif; }
      h1,h2,h3,.serif { font-family:'Fraunces',serif; letter-spacing:-0.01em; font-weight:500; }
      body h1, body h2, body h3, body h4 { color:inherit; }
      .wrap { width:min(1160px,100%-3rem); margin-inline:auto; }
      .ed-nav { position:sticky; top:0; z-index:50; background:rgba(244,241,236,0.85); backdrop-filter:blur(12px); border-bottom:1px solid var(--e-line); }
      .rise { opacity:0; transform:translateY(26px); transition:opacity .9s cubic-bezier(.16,1,.3,1), transform .9s cubic-bezier(.16,1,.3,1); }
      .rise.in { opacity:1; transform:none; }
      .eyebrow { font-size:.72rem; font-weight:600; letter-spacing:.22em; text-transform:uppercase; color:var(--e-mut); }
      details { border-bottom:1px solid var(--e-line); }
      summary { list-style:none; cursor:pointer; padding:1.2rem 0; display:flex; justify-content:space-between; gap:1rem; font-family:'Fraunces',serif; font-weight:500; font-size:1.1rem; }
      summary::-webkit-details-marker { display:none; }
      .ed-btn { display:inline-flex; align-items:center; gap:.5rem; font-size:.78rem; font-weight:600; letter-spacing:.14em; text-transform:uppercase; }
    </style>
  </head>
  <body>
    <header class="ed-nav">
      <div class="wrap" style="display:flex; align-items:center; justify-content:space-between; height:66px;">
        <a href="/" class="serif" style="display:flex; align-items:center; gap:.5rem; color:var(--e-ink); text-decoration:none; font-size:1.2rem; font-weight:600;">
          <svg width="24" height="24" viewBox="0 0 48 48" fill="none"><path d="M13 38 L24 12 L35 38" stroke="#2b2c2a" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Astro Care</a>
        <nav style="display:flex; gap:2rem;" class="hide-sm">{['Services','How it works','Funding','FAQ'].map((l,i)=>(<a href={['#services','#how','#funding','#faq'][i]} class="eyebrow" style="text-decoration:none;">{l}</a>))}</nav>
        <a href="#contact" class="ed-btn" style="color:var(--e-ink); text-decoration:none;">Enquire <span style="display:inline-flex; width:22px; height:22px; align-items:center; justify-content:center; border:1px solid var(--e-ink); border-radius:999px;">→</span></a>
      </div>
    </header>

    <!-- HERO -->
    <section class="wrap" style="padding:2rem 0 3rem;">
      <div style="position:relative; border-radius:14px; overflow:hidden; box-shadow:0 30px 60px rgba(60,66,70,0.22); aspect-ratio:16/9; min-height:440px;">
        <img src="/media/div-3.jpg" alt="" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;" />
        <div style="position:absolute; inset:0; background:linear-gradient(90deg, rgba(48,52,55,0.78) 0%, rgba(48,52,55,0.3) 48%, rgba(48,52,55,0.08) 100%);"></div>
        <div style="position:absolute; left:2rem; right:2rem; bottom:2.4rem; color:#fff;" class="hero-copy">
          <p class="eyebrow" style="color:rgba(255,255,255,0.8);">Melbourne · aged care at home</p>
          <h1 style="margin:.5rem 0 0; color:#fff; font-size:clamp(2.4rem,5.5vw,4.2rem); line-height:1.02; max-width:16ch;">Home is where care should be.</h1>
          <p style="margin:1rem 0 0; max-width:34ch; color:rgba(255,255,255,0.85); font-size:1rem;">Gentle, reliable help — so getting older never means leaving the home you love.</p>
          <div style="margin-top:1.6rem; display:flex; gap:1.4rem; flex-wrap:wrap; align-items:center;">
            <a href="#contact" class="ed-btn" style="color:#fff; text-decoration:none; background:#fff; color:var(--e-ink); padding:.8rem 1.4rem; border-radius:999px;">Book a callback</a>
            <a href="#services" class="ed-btn" style="color:#fff; text-decoration:none;">Explore <span style="display:inline-flex; width:22px; height:22px; align-items:center; justify-content:center; border:1px solid #fff; border-radius:999px;">→</span></a>
          </div>
        </div>
      </div>
      <div style="display:flex; flex-wrap:wrap; gap:3rem; border-bottom:1px solid var(--e-line); padding:1.8rem 0;">
        {[['Service area','All Melbourne'],['Callback','1 day'],['Care','24 / 7'],['Lock-in','None']].map(([l,v])=>(
          <div class="rise"><p class="eyebrow">{l}</p><p class="serif" style="margin:.3rem 0 0; font-size:1.5rem; font-weight:600;">{v}</p></div>
        ))}
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="wrap" style="padding:2.5rem 0;">
      <p class="eyebrow rise">What we do</p>
      <h2 class="rise" style="margin:.5rem 0 2rem; font-size:clamp(1.9rem,4vw,3rem);">A full circle of care</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:1.6rem;">
        {services.map(([t,d,img])=>(
          <article class="rise" style="background:var(--e-paper); border:1px solid var(--e-line); border-radius:12px; overflow:hidden;">
            <div style="aspect-ratio:16/10; overflow:hidden;"><img src={img} alt="" style="width:100%; height:100%; object-fit:cover;"/></div>
            <div style="padding:1.3rem;"><h3 style="margin:0; font-size:1.25rem;">{t}</h3><p style="margin:.5rem 0 0; color:var(--e-mut); font-size:.92rem;">{d}</p></div>
          </article>
        ))}
      </div>
    </section>

    <!-- HOW -->
    <section id="how" style="background:var(--e-paper); border-block:1px solid var(--e-line); padding:3.5rem 0;">
      <div class="wrap">
        <p class="eyebrow rise">Getting started</p>
        <h2 class="rise" style="margin:.5rem 0 2.2rem; font-size:clamp(1.9rem,4vw,3rem);">Three unhurried steps</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:2rem;">
          {steps.map(([n,t,d])=>(
            <div class="rise"><p class="serif" style="margin:0; font-size:2.6rem; font-weight:400; color:var(--e-gold);">{n}</p><h3 style="margin:.5rem 0 .4rem; font-size:1.4rem;">{t}</h3><p style="margin:0; color:var(--e-mut); font-size:.95rem;">{d}</p></div>
          ))}
        </div>
      </div>
    </section>

    <!-- FUNDING -->
    <section id="funding" class="wrap" style="padding:3.5rem 0;">
      <p class="eyebrow rise">Funding</p>
      <h2 class="rise" style="margin:.5rem 0 2rem; font-size:clamp(1.9rem,4vw,3rem);">The government pays for most of it</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.6rem;">
        {funding.map(([t,tag,d])=>(
          <div class="rise" style="background:var(--e-paper); border:1px solid var(--e-line); border-radius:12px; padding:1.7rem;">
            <span class="eyebrow" style="color:var(--e-gold);">{tag}</span>
            <h3 style="margin:.6rem 0 .5rem; font-size:1.35rem;">{t}</h3>
            <p style="margin:0; color:var(--e-mut); font-size:.93rem;">{d}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" style="background:var(--e-paper); border-block:1px solid var(--e-line); padding:3.5rem 0;">
      <div class="wrap" style="max-width:820px;">
        <h2 class="rise" style="margin:0 0 1.4rem; font-size:clamp(1.9rem,4vw,2.8rem);">The things families ask first</h2>
        {faqs.map(([q,a])=>(
          <details class="rise"><summary>{q}<span style="color:var(--e-gold); font-family:'Instrument Sans';">+</span></summary><p style="margin:0 0 1.2rem; color:var(--e-mut); font-size:.96rem;">{a}</p></details>
        ))}
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="wrap" style="padding:4rem 0;">
      <div class="rise" style="text-align:center; border:1px solid var(--e-line); border-radius:14px; padding:3rem 2rem; background:var(--e-paper);">
        <p class="eyebrow">No pressure, no obligation</p>
        <h2 style="margin:.6rem 0 0; font-size:clamp(2rem,4.5vw,3.2rem);">Let’s have a chat.</h2>
        <p style="margin:.9rem auto 1.8rem; max-width:38ch; color:var(--e-mut);">Just honest answers about the help you can get. We ring back within one business day.</p>
        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
          <a href="tel:+611800278762" class="ed-btn" style="text-decoration:none; background:var(--e-ink); color:#fff; padding:.9rem 1.6rem; border-radius:999px;">1800 ASTRO</a>
          <a href="mailto:info@astrocare.com.au" class="ed-btn" style="text-decoration:none; color:var(--e-ink); border:1px solid var(--e-ink); padding:.9rem 1.6rem; border-radius:999px;">Email us</a>
        </div>
      </div>
    </section>

    <footer style="border-top:1px solid var(--e-line); padding:2rem 0; color:var(--e-mut); font-size:.85rem;">
      <div class="wrap" style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:1rem;"><span>© 2026 Astro Care Group Pty Ltd · ABN 99 700 192 981</span><span>Aged care at home · All of Melbourne</span></div>
    </footer>

    <script is:inline>
      var io = new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:0,rootMargin:'0px 0px -8% 0px'});
      document.querySelectorAll('.rise').forEach(function(el){io.observe(el)});
      var s=document.createElement('style'); s.textContent='@media(max-width:640px){.hide-sm{display:none!important}}'; document.head.appendChild(s);
    </script>
  </body>
</html>
