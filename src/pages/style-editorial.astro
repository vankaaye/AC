---
import '../styles/global.css';
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Astro Care — Editorial concept</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>body { background: #8a9297; }</style>
  </head>
  <body class="flex min-h-screen items-center justify-center p-3 md:p-10" style="font-family: 'Instrument Sans', sans-serif;">
    <div class="relative w-full max-w-6xl overflow-hidden rounded-xl shadow-2xl" style="aspect-ratio: 16 / 9; min-height: 460px;">
      <img src="/media/div-3.jpg" alt="" class="absolute inset-0 h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(60,66,70,0.72) 0%, rgba(60,66,70,0.28) 45%, rgba(60,66,70,0.1) 100%);"></div>

      <!-- top -->
      <nav class="absolute inset-x-0 top-0 flex items-center justify-between px-8 py-7 text-white md:px-12">
        <div class="flex items-center gap-2 text-lg font-semibold tracking-tight" style="font-family: 'Fraunces', serif;">
          <svg class="h-6 w-6" viewBox="0 0 48 48" fill="none"><path d="M13 38 L24 12 L35 38" stroke="#fff" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Astro Care
        </div>
        <div class="flex gap-8 text-[0.8rem] font-semibold uppercase tracking-widest text-white/85">
          <span>Services</span><span>Stories</span>
        </div>
      </nav>

      <!-- arrows -->
      <button class="absolute left-3 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full text-white" style="background: rgba(30,34,38,0.5);" aria-label="Previous">‹</button>
      <button class="absolute right-3 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full text-white" style="background: rgba(30,34,38,0.5);" aria-label="Next">›</button>

      <!-- content -->
      <div class="absolute bottom-10 left-8 right-8 text-white md:left-12">
        <div class="mb-6 flex h-11 w-11 items-center justify-center rounded-full border text-xs" style="border-color: rgba(255,255,255,0.5);">1/4</div>
        <p class="text-[0.8rem] font-semibold uppercase tracking-widest text-white/75">Melbourne · aged care at home</p>
        <h1 class="mt-2 max-w-xl" style="font-family: 'Fraunces', serif; font-weight: 500; font-size: clamp(2.4rem, 5.5vw, 4rem); line-height: 1.02;">Home is where<br />care should be.</h1>
        <p class="mt-3 max-w-sm text-[0.95rem] text-white/80">Gentle, reliable help — so getting older never means leaving the home you love.</p>
        <a href="/#contact" class="mt-6 inline-flex items-center gap-2 text-[0.8rem] font-bold uppercase tracking-widest text-white">Explore <span class="flex h-6 w-6 items-center justify-center rounded-full border" style="border-color:#fff;">→</span></a>

        <!-- stats row -->
        <div class="mt-8 flex flex-wrap gap-x-14 gap-y-4 border-t pt-5" style="border-color: rgba(255,255,255,0.25);">
          <div><p class="text-[0.7rem] uppercase tracking-widest text-white/60">Service area</p><p class="mt-1 text-xl font-bold" style="font-family:'Fraunces',serif;">All Melbourne</p></div>
          <div><p class="text-[0.7rem] uppercase tracking-widest text-white/60">Callback</p><p class="mt-1 text-xl font-bold" style="font-family:'Fraunces',serif;">1 day</p></div>
          <div><p class="text-[0.7rem] uppercase tracking-widest text-white/60">Care</p><p class="mt-1 text-xl font-bold" style="font-family:'Fraunces',serif;">24 / 7</p></div>
        </div>
      </div>
    </div>
  </body>
</html>
