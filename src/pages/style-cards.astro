---
import '../styles/global.css';
const services = [
  ['Clinical & nursing care', 'Wound care, medication, health checks & recovery — by registered nurses.', '/media/poster-clinical.jpg'],
  ['Personal care', 'A gentle hand with showering, dressing and getting ready for the day.', '/media/loop-personal.jpg'],
  ['Allied health & therapy', 'Physio, OT and exercise to keep you strong, steady and moving well.', '/media/loop-allied.jpg'],
  ['Domestic assistance', 'Cleaning, laundry and light gardening — home kept safe and lovely.', '/media/poster-domestic.jpg'],
  ['Meal preparation', 'Fresh meals cooked your way, with good company while they’re made.', '/media/poster-meals.jpg'],
  ['Social support & company', 'Friendly visits, outings and someone to share a cuppa and a laugh.', '/media/poster-social.jpg'],
  ['Transport & getting out', 'Lifts to appointments, the shops or a favourite spot — company along the way.', '/media/loop-transport.jpg'],
  ['Respite & overnight care', 'A trusted hand so family carers can rest — hours or overnight.', '/media/loop-respite.jpg'],
];
const steps = [
  ['01', 'Say hello', 'Chat with us online or leave your number — no obligation.'],
  ['02', 'We sort the funding', 'We guide you through My Aged Care and handle the paperwork with you.'],
  ['03', 'Care begins at home', 'Your support workers arrive when you want them — and it flexes as needs change.'],
];
const funding = [
  ['Support at Home', 'Most people start here', 'The government program for care at home — funded on your assessed needs, from about $11,000 to $78,000 a year.'],
  ['CHSP', 'Entry-level help', 'A little help — cleaning, meals or transport — with a small contribution per service.'],
  ['Private care', 'No waiting', 'Start straight away from $65/hour and switch to government funding once approved.'],
];
const faqs = [
  ['Who is eligible for funded care?', 'Generally Australians 65+ (50+ for First Nations people) who need help to keep living at home. A free My Aged Care assessment confirms it — we help you arrange it.'],
  ['How much will it cost us?', 'The government pays the large majority for most people. Our fees are 15% care + 10% package management, under the caps, all published.'],
  ['How quickly can care start?', 'Privately within days; government-funded depends on the queue. Many start privately and switch when funding is approved.'],
  ['Where do you operate?', 'Right across Melbourne — inner suburbs to the outer ring.'],
];
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><meta name="robots" content="noindex" />
    <title>Astro Care — Glass cards concept (full)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@400;500;600;700&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      :root { --k-bg:#0e1418; --k-ink:#22303c; --k-mut:#5c6b78; --k-euca:#0C6291; --k-sun:#E8A33D; }
      * { box-sizing:border-box; }
      body { margin:0; background:#eef2f4; color:var(--k-ink); font-family:'Instrument Sans',sans-serif; }
      h1,h2,h3 { font-family:'Schibsted Grotesk',sans-serif; letter-spacing:-0.02em; }
      body h1, body h2, body h3, body h4 { color:inherit; }
      .wrap { width:min(1180px,100%-2.5rem); margin-inline:auto; }
      .rise { opacity:0; transform:translateY(26px); transition:opacity .9s cubic-bezier(.16,1,.3,1), transform .9s cubic-bezier(.16,1,.3,1); }
      .rise.in { opacity:1; transform:none; }
      .k-btn { display:inline-flex; align-items:center; gap:.5rem; border-radius:999px; padding:.7rem 1.4rem; font-weight:700; font-size:.88rem; }
      .k-card { background:#fff; border-radius:1.4rem; box-shadow:0 12px 30px rgba(30,50,70,0.08); overflow:hidden; }
      details { border-bottom:1px solid #e2e8ec; }
      summary { list-style:none; cursor:pointer; padding:1.1rem 0; display:flex; justify-content:space-between; gap:1rem; font-weight:700; font-family:'Schibsted Grotesk'; }
      summary::-webkit-details-marker { display:none; }
    </style>
  </head>
  <body>
    <!-- HERO: full-bleed video with floating glass shell -->
    <section style="padding:1rem;">
      <div style="position:relative; border-radius:1.8rem; overflow:hidden; min-height:88vh; display:flex; flex-direction:column;">
        <video style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;" src="/media/hero-1080.mp4" poster="/media/hero-1080-poster.jpg" autoplay muted loop playsinline></video>
        <div style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(10,20,28,0.45) 0%, rgba(10,20,28,0.1) 30%, rgba(10,20,28,0.55) 100%);"></div>

        <!-- pill nav -->
        <nav class="wrap" style="position:relative; display:flex; align-items:center; justify-content:space-between; padding:1.2rem 0;">
          <a href="/" style="display:flex; align-items:center; gap:.5rem; color:#fff; text-decoration:none; font-weight:700; font-family:'Schibsted Grotesk';">
            <svg width="28" height="28" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" fill="rgba(255,255,255,0.92)"/><path d="M13 38 L24 12 L35 38" stroke="#0C6291" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/></svg>Astro Care</a>
          <div class="hide-sm" style="display:flex; align-items:center; gap:.2rem; border-radius:999px; padding:.35rem; font-size:.82rem; font-weight:600; color:#fff; background:rgba(255,255,255,0.16); backdrop-filter:blur(8px);">
            <a href="#services" style="padding:.5rem 1rem; border-radius:999px; color:inherit; text-decoration:none;">Services</a><a href="#how" style="padding:.5rem 1rem; color:inherit; text-decoration:none;">How it works</a><a href="#funding" style="padding:.5rem 1rem; color:inherit; text-decoration:none;">Funding</a><a href="#faq" style="padding:.5rem 1rem; color:inherit; text-decoration:none;">FAQ</a>
          </div>
          <a href="#contact" class="k-btn" style="background:#fff; color:var(--k-ink);">Book now ↗</a>
        </nav>

        <!-- headline -->
        <div class="wrap" style="position:relative; flex:1; display:flex; flex-direction:column; justify-content:center; text-align:center; padding:2rem 0;">
          <span style="align-self:center; display:inline-block; border-radius:999px; background:rgba(255,255,255,0.2); backdrop-filter:blur(8px); padding:.4rem 1.1rem; font-size:.8rem; font-weight:600; color:#fff;">Aged care at home · Melbourne</span>
          <h1 style="margin:1rem 0 0; color:#fff; font-weight:500; font-size:clamp(2.4rem,6.5vw,4.6rem); line-height:1.03; text-shadow:0 2px 24px rgba(10,20,28,0.45);">Care at home,<br/>beautifully done.</h1>
          <p style="margin:1rem auto 0; max-width:46ch; color:rgba(255,255,255,0.9); font-size:1.05rem;">Nursing, everyday help and genuine company — funded for most over 65.</p>
          <div style="display:flex; gap:.8rem; justify-content:center; margin-top:1.6rem; flex-wrap:wrap;">
            <a href="#contact" class="k-btn" style="background:var(--k-sun); color:#22303c;">Book a callback ↗</a>
            <a href="#services" class="k-btn" style="background:rgba(255,255,255,0.16); color:#fff; border:1px solid rgba(255,255,255,0.5); backdrop-filter:blur(8px);">Explore services</a>
          </div>
        </div>

        <!-- bottom social proof + service cards row -->
        <div class="wrap" style="position:relative; display:flex; flex-wrap:wrap; gap:1rem; align-items:flex-end; justify-content:space-between; padding-bottom:1.4rem;">
          <div style="max-width:20rem; border-radius:1.2rem; padding:1.2rem; background:rgba(255,255,255,0.18); backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.3);">
            <div style="display:flex; align-items:center; gap:.7rem;">
              <div style="display:flex;">
                <span style="width:32px;height:32px;border-radius:999px;border:2px solid #fff;background:#7fa8c9;margin-right:-8px;"></span>
                <span style="width:32px;height:32px;border-radius:999px;border:2px solid #fff;background:#c9a17f;margin-right:-8px;"></span>
                <span style="width:32px;height:32px;border-radius:999px;border:2px solid #fff;background:#9fbf9f;margin-right:-8px;"></span>
                <span style="width:32px;height:32px;border-radius:999px;border:2px solid #fff;background:#22303c;color:#fff;font-size:.6rem;font-weight:700;display:flex;align-items:center;justify-content:center;">500+</span>
              </div>
              <span style="font-size:.85rem; font-weight:700; color:#fff;">families helped</span>
            </div>
            <p style="margin:.7rem 0 0; font-size:.85rem; color:rgba(255,255,255,0.9);">Nursing, everyday help and genuine company — funded for most over 65.</p>
          </div>
          <div class="hide-sm" style="display:flex; gap:.7rem;">
            {services.slice(0,4).map(([t,,img])=>(
              <div style="position:relative; width:118px; height:150px; border-radius:1rem; overflow:hidden; border:1px solid rgba(255,255,255,0.35);">
                <img src={img} alt="" style="width:100%; height:100%; object-fit:cover;"/>
                <span style="position:absolute; inset-inline:0; bottom:0; padding:.5rem; font-size:.68rem; font-weight:600; color:#fff; background:linear-gradient(0deg, rgba(10,20,28,0.75), transparent);">{t}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="wrap" style="padding:3rem 0;">
      <p class="rise" style="color:var(--k-euca); font-weight:700; letter-spacing:.14em; text-transform:uppercase; font-size:.78rem; margin:0;">What we do</p>
      <h2 class="rise" style="margin:.4rem 0 2rem; font-size:clamp(1.9rem,4vw,2.9rem);">Pick the help you need</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:1.2rem;">
        {services.map(([t,d,img])=>(
          <article class="k-card rise">
            <div style="aspect-ratio:16/10; overflow:hidden;"><img src={img} alt="" style="width:100%; height:100%; object-fit:cover;"/></div>
            <div style="padding:1.2rem;"><h3 style="margin:0; font-size:1.1rem;">{t}</h3><p style="margin:.5rem 0 0; color:var(--k-mut); font-size:.9rem;">{d}</p></div>
          </article>
        ))}
      </div>
    </section>

    <!-- HOW -->
    <section id="how" style="background:#fff; padding:3.5rem 0;">
      <div class="wrap">
        <p class="rise" style="color:var(--k-euca); font-weight:700; letter-spacing:.14em; text-transform:uppercase; font-size:.78rem; margin:0;">Getting started</p>
        <h2 class="rise" style="margin:.4rem 0 2rem; font-size:clamp(1.9rem,4vw,2.9rem);">Three easy steps</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:1.2rem;">
          {steps.map(([n,t,d])=>(
            <div class="rise" style="background:#f3f6f8; border-radius:1.2rem; padding:1.6rem;"><p style="margin:0; font-size:2.4rem; font-weight:700; color:rgba(12,98,145,0.3); font-family:'Schibsted Grotesk';">{n}</p><h3 style="margin:.3rem 0 .4rem; font-size:1.2rem;">{t}</h3><p style="margin:0; color:var(--k-mut); font-size:.92rem;">{d}</p></div>
          ))}
        </div>
      </div>
    </section>

    <!-- FUNDING -->
    <section id="funding" class="wrap" style="padding:3.5rem 0;">
      <p class="rise" style="color:var(--k-euca); font-weight:700; letter-spacing:.14em; text-transform:uppercase; font-size:.78rem; margin:0;">Funding</p>
      <h2 class="rise" style="margin:.4rem 0 2rem; font-size:clamp(1.9rem,4vw,2.9rem);">The government pays for most of it</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.2rem;">
        {funding.map(([t,tag,d])=>(
          <div class="k-card rise" style="padding:1.6rem;"><span style="display:inline-block; border-radius:999px; background:rgba(12,98,145,0.1); color:var(--k-euca); padding:.3rem .8rem; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em;">{tag}</span><h3 style="margin:.6rem 0 .5rem; font-size:1.25rem;">{t}</h3><p style="margin:0; color:var(--k-mut); font-size:.92rem;">{d}</p></div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" style="background:#fff; padding:3.5rem 0;">
      <div class="wrap" style="max-width:840px;">
        <h2 class="rise" style="margin:0 0 1.4rem; font-size:clamp(1.9rem,4vw,2.7rem);">The things families ask first</h2>
        {faqs.map(([q,a])=>(
          <details class="rise"><summary>{q}<span style="color:var(--k-euca);">+</span></summary><p style="margin:0 0 1.1rem; color:var(--k-mut); font-size:.94rem;">{a}</p></details>
        ))}
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="wrap" style="padding:4rem 0;">
      <div class="rise" style="position:relative; border-radius:1.8rem; overflow:hidden; padding:3rem 2rem; text-align:center; color:#fff;">
        <img src="/media/poster-social.jpg" alt="" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;"/>
        <div style="position:absolute; inset:0; background:linear-gradient(120deg, rgba(12,98,145,0.94), rgba(18,35,58,0.9));"></div>
        <div style="position:relative;">
          <h2 style="margin:0; font-size:clamp(2rem,4.5vw,3rem); color:#fff;">Let’s have a chat</h2>
          <p style="margin:.9rem auto 1.8rem; max-width:40ch; color:rgba(255,255,255,0.9);">No pressure, no obligation — just honest answers about the help you can get. We ring back within one business day.</p>
          <div style="display:flex; gap:.8rem; justify-content:center; flex-wrap:wrap;">
            <a href="tel:+611800278762" class="k-btn" style="background:var(--k-sun); color:#22303c;">1800 ASTRO</a>
            <a href="mailto:info@astrocare.com.au" class="k-btn" style="background:rgba(255,255,255,0.16); color:#fff; border:1px solid rgba(255,255,255,0.5);">Email us</a>
          </div>
        </div>
      </div>
    </section>

    <footer style="border-top:1px solid #e2e8ec; padding:2rem 0; color:var(--k-mut); font-size:.85rem;">
      <div class="wrap" style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:1rem;"><span>© 2026 Astro Care Group Pty Ltd · ABN 99 700 192 981</span><span>Aged care at home · All of Melbourne</span></div>
    </footer>

    <script is:inline>
      var io = new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:0,rootMargin:'0px 0px -8% 0px'});
      document.querySelectorAll('.rise').forEach(function(el){io.observe(el)});
      var s=document.createElement('style'); s.textContent='@media(max-width:640px){.hide-sm{display:none!important}}'; document.head.appendChild(s);
    </script>
  </body>
</html>
