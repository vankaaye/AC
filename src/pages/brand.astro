---
/**
 * brand.astro — astrocare.com.au/brand
 * ------------------------------------------------------------------
 * The Astro Care brand chooser: 20 logo concepts × 5 colourways
 * (200 numbered options), each with a live preview of how it looks
 * as the browser-tab icon beside the "Astro Care" name, plus 30
 * numbered tagline options. Pick a number, tell us, done.
 * ------------------------------------------------------------------
 */
import Layout from '../layouts/Layout.astro';

const tagGroups: [string, [string, string][]][] = [
  [
    'Plain & true — say it straight',
    [
      ['T1', 'Good care. No fuss.'],
      ['T2', 'We look after people. It\'s that simple.'],
      ['T3', 'Care done properly.'],
      ['T4', 'The right help, at the right time.'],
      ['T5', 'Here when you need us.'],
      ['T6', 'Straight answers. Gentle care.'],
      ['T7', 'We turn up. We care. We follow through.'],
      ['T8', 'It starts with listening.'],
      ['T9', 'Every visit matters.'],
      ['T10', 'We make care simple.'],
    ],
  ],
  [
    'Warm & personal — the way we\'d say it over a cuppa',
    [
      ['T11', 'Small team. Big hearts.'],
      ['T12', 'No call centres. Just people who care.'],
      ['T13', 'Help that feels human.'],
      ['T14', 'We treat you like family — because that\'s how care should feel.'],
      ['T15', 'Looking after you, properly.'],
      ['T16', 'Care with its sleeves rolled up.'],
      ['T17', 'Honest hands. Steady care.'],
      ['T18', 'Because everyone deserves good care.'],
      ['T19', 'Health care, the way it used to feel.'],
      ['T20', 'Care you don\'t have to chase.'],
    ],
  ],
  [
    'Whole of health — room to grow beyond aged care',
    [
      ['T21', 'Care for every stage of life.'],
      ['T22', 'One team for all your care.'],
      ['T23', 'From hospital to home, we\'ve got you.'],
      ['T24', 'Whatever care you need, start here.'],
      ['T25', 'Your health. Our responsibility.'],
      ['T26', 'Live well, at every age.'],
      ['T27', 'Health at home, life in full.'],
      ['T28', 'Care that grows with you.'],
      ['T29', 'Good health starts with good people.'],
      ['T30', 'All of your care, under one roof.'],
    ],
  ],
];
---

<Layout
  title="Astro Care — Logo & Tagline Options"
  description="Choose the Astro Care logo (200 numbered options) and tagline (30 options)."
>
  <section class="py-10 md:py-14" style="background: var(--bg-sand);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
      <p class="mb-2 text-lg font-extrabold uppercase tracking-widest" style="font-family: var(--font-head); color: var(--sun-deep);">
        Brand options
      </p>
      <h1 class="mb-4 text-3xl md:text-5xl">200 logo options &amp; 30 taglines</h1>
      <p class="max-w-3xl text-xl" style="color: var(--tx-soft);">
        "Astro" is the brand name — the marks below speak to <strong>health care as a whole</strong>:
        hearts, caring hands, people, wellbeing and protection. Twenty concepts, each in ten
        colourways — <strong>200 numbered options</strong>, each previewed as the icon in a
        <strong>browser tab</strong> beside the "Astro Care" name. Taglines are at the bottom.
        <strong>To choose, just tell us a logo number and a T-number.</strong>
      </p>
      <div class="legend mt-5" id="legend"></div>
    </div>
  </section>

  <section class="py-8 md:py-12" style="background: var(--bg);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]" id="gallery"></div>
  </section>

  <section class="py-10 md:py-14" style="background: var(--bg-sand);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
      <h2 class="mb-6 text-3xl md:text-4xl">30 tagline options</h2>
      {
        tagGroups.map(([title, tags]) => (
          <div class="mb-8">
            <h3 class="mb-4 text-2xl" style="color: var(--euca);">{title}</h3>
            <ol class="grid gap-3 md:grid-cols-2">
              {tags.map(([num, text]) => (
                <li class="flex items-baseline gap-3 rounded-2xl border-2 px-4 py-3 text-xl" style="background: var(--bg-card); border-color: var(--line);">
                  <b class="text-lg" style="color: var(--sun-deep); font-variant-numeric: tabular-nums;">{num}</b>
                  {text}
                </li>
              ))}
            </ol>
          </div>
        ))
      }
      <div class="rounded-3xl border-l-8 p-6 text-xl" style="background: var(--bg-card); border-color: var(--sun); box-shadow: var(--shadow);">
        <p><strong>How to choose:</strong> tell us a logo number (1–200) and a tagline (T1–T30) — for example, "logo 12 and T5".</p>
        <p class="mt-2" style="color: var(--tx-soft);">We'll make it the official mark, the browser-tab icon and the site-wide tagline.</p>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .legend { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .legend span {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--bg-card); border: 2px solid var(--line);
    border-radius: 999px; padding: 0.35rem 0.9rem 0.35rem 0.45rem;
    font-size: 1rem; font-weight: 700;
  }
  .legend i { width: 24px; height: 24px; border-radius: 50%; display: inline-block; border: 1px solid rgba(0,0,0,0.15); }

  .brand-family { font-size: 1.5rem; font-weight: 900; font-family: var(--font-head); margin: 2.2rem 0 0.2rem; }
  .brand-family small { font-weight: 700; color: var(--tx-soft); font-size: 1.05rem; }
  .brand-note { color: var(--tx-soft); font-size: 1.1rem; margin: 0 0 1rem; max-width: 70ch; }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.8rem;
  }
  @media (min-width: 640px) { .brand-grid { grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 1rem; } }

  .brand-card {
    background: var(--bg-card);
    border: 2px solid var(--line);
    border-radius: 16px;
    padding: 1rem 0.85rem 0.85rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.7rem;
  }
  .brand-card .num {
    align-self: flex-start;
    font-size: 0.95rem; font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--sun-deep);
    background: var(--sun-soft);
    border-radius: 8px; padding: 0.1rem 0.55rem;
  }
  .brand-card svg.mark { width: 84px; height: 84px; }
  .brand-tab {
    display: flex; align-items: center; gap: 0.45rem;
    width: 100%;
    background: var(--line);
    border-radius: 8px 8px 3px 3px;
    padding: 0.4rem 0.6rem;
    font-size: 0.85rem; font-weight: 700; color: var(--tx);
    overflow: hidden; white-space: nowrap;
  }
  .brand-tab svg.mini { width: 16px; height: 16px; flex: none; }
  .brand-tab .x { margin-left: auto; color: var(--tx-soft); font-weight: 400; }
  .brand-card .cw { font-size: 0.9rem; color: var(--tx-soft); text-align: center; }
</style>

<script is:inline>
  /* Generates 20 mark concepts × 5 colourways = 100 numbered logos. */
  (function () {
    var PALETTES = [
      { key: 'A', name: 'Eucalyptus',  bg: '#2F6B51', fg: '#FFC24B', ac: '#FFFFFF', ring: null },
      { key: 'B', name: 'Sunrise',     bg: '#FFC24B', fg: '#2F6B51', ac: '#B23E1F', ring: null },
      { key: 'C', name: 'Night Sky',   bg: '#1F3A5F', fg: '#FFD98E', ac: '#FFFFFF', ring: null },
      { key: 'D', name: 'Fresh White', bg: '#FFFFFF', fg: '#2F6B51', ac: '#E2A93B', ring: '#2F6B51' },
      { key: 'E', name: 'Terracotta',  bg: '#B95C38', fg: '#FFF3D6', ac: '#FFC24B', ring: null },
      { key: 'F', name: 'Ocean Teal',  bg: '#0F7E77', fg: '#FFF8E7', ac: '#FFC24B', ring: null },
      { key: 'G', name: 'Sky Mist',    bg: '#E7F1FA', fg: '#1F5F8B', ac: '#C94F30', ring: '#1F5F8B' },
      { key: 'H', name: 'Plum',        bg: '#5E4364', fg: '#F5E9D9', ac: '#E8B34B', ring: null },
      { key: 'I', name: 'Charcoal',    bg: '#2A2E2B', fg: '#F2EFE6', ac: '#FFC24B', ring: null },
      { key: 'J', name: 'Sage',        bg: '#6E7F5C', fg: '#FFF9EC', ac: '#F2C14E', ring: null },
    ];


    function heart(cx, cy, w, fill, stroke) {
      var h = w * 0.95;
      var d = 'M' + cx + ' ' + (cy + h * 0.48) +
        ' C' + (cx - w * 0.5) + ' ' + (cy + h * 0.12) + ' ' + (cx - w * 0.52) + ' ' + (cy - h * 0.28) + ' ' + (cx - w * 0.26) + ' ' + (cy - h * 0.38) +
        ' A' + (w * 0.26) + ' ' + (w * 0.26) + ' 0 0 1 ' + cx + ' ' + (cy - h * 0.18) +
        ' A' + (w * 0.26) + ' ' + (w * 0.26) + ' 0 0 1 ' + (cx + w * 0.26) + ' ' + (cy - h * 0.38) +
        ' C' + (cx + w * 0.52) + ' ' + (cy - h * 0.28) + ' ' + (cx + w * 0.5) + ' ' + (cy + h * 0.12) + ' ' + cx + ' ' + (cy + h * 0.48) + ' Z';
      return stroke
        ? '<path d="' + d + '" fill="none" stroke="' + fill + '" stroke-width="2.6" stroke-linejoin="round"/>'
        : '<path d="' + d + '" fill="' + fill + '"/>';
    }
    function pulse(x, y, w, color) {
      var u = w / 10;
      return '<path d="M' + x + ' ' + y + ' h' + (2.2 * u) + ' l' + (1.1 * u) + ' -' + (2.6 * u) +
        ' l' + (1.6 * u) + ' ' + (5.2 * u) + ' l' + (1.4 * u) + ' -' + (3.4 * u) + ' l' + (0.8 * u) + ' ' + (0.8 * u) +
        ' h' + (2.9 * u) + '" fill="none" stroke="' + color + '" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>';
    }
    function person(cx, cy, r, fill) {
      return '<circle cx="' + cx + '" cy="' + (cy - r * 1.1) + '" r="' + (r * 0.62) + '" fill="' + fill + '"/>' +
        '<path d="M' + (cx - r) + ' ' + (cy + r * 0.9) + ' a' + r + ' ' + r + ' 0 0 1 ' + (2 * r) + ' 0 Z" fill="' + fill + '"/>';
    }
    function leaf(cx, cy, rx, ry, rot, fill) {
      return '<ellipse cx="' + cx + '" cy="' + cy + '" rx="' + rx + '" ry="' + ry + '" fill="' + fill + '" transform="rotate(' + rot + ' ' + cx + ' ' + cy + ')"/>';
    }

    var MARKS = [
      { name: 'Heart', note: 'The simplest promise — care, plainly and warmly drawn.',
        draw: function (p) { return heart(24, 24, 26, p.fg); } },
      { name: 'Heartbeat', note: 'A heart with a pulse — clinical skill inside human warmth.',
        draw: function (p) { return heart(24, 24, 28, p.fg, true) + pulse(14, 24.5, 20, p.ac); } },
      { name: 'Pulse Ring', note: 'A steady heartbeat, held in a circle of care.',
        draw: function (p) { return '<circle cx="24" cy="24" r="14.5" fill="none" stroke="' + p.fg + '" stroke-width="2.6"/>' + pulse(14.5, 24.5, 19, p.ac); } },
      { name: 'Cradled Heart', note: 'A hand holding a heart — support without gripping.',
        draw: function (p) { return heart(24, 18.5, 17, p.fg) + '<path d="M11 29 q6 8 13 8 q7 0 13 -8" fill="none" stroke="' + p.ac + '" stroke-width="2.8" stroke-linecap="round"/><path d="M9 24 q1.5 4.5 5 6.8 M39 24 q-1.5 4.5 -5 6.8" fill="none" stroke="' + p.ac + '" stroke-width="2.8" stroke-linecap="round"/>'; } },
      { name: 'Circle of Care', note: 'Two arms of a circle around a person — never alone.',
        draw: function (p) { return '<path d="M24 7 a17 17 0 0 1 15 25" fill="none" stroke="' + p.fg + '" stroke-width="3.2" stroke-linecap="round"/><path d="M24 41 a17 17 0 0 1 -15 -25" fill="none" stroke="' + p.ac + '" stroke-width="3.2" stroke-linecap="round"/>' + person(24, 24, 7.5, p.fg); } },
      { name: 'Side by Side', note: 'Carer and client together — help as companionship.',
        draw: function (p) { return person(18, 25, 8, p.fg) + person(31.5, 26.5, 6.2, p.ac); } },
      { name: 'Family', note: 'Three generations shoulder to shoulder.',
        draw: function (p) { return person(14, 26, 6.4, p.ac) + person(24, 24.5, 8, p.fg) + person(34, 26.5, 5.6, p.ac); } },
      { name: 'Soft Cross', note: 'The universal mark of health, rounded and friendly.',
        draw: function (p) { return '<path d="M19.5 10 h9 a2.5 2.5 0 0 1 2.5 2.5 v7 h7 a2.5 2.5 0 0 1 2.5 2.5 v4 a2.5 2.5 0 0 1 -2.5 2.5 h-7 v7 a2.5 2.5 0 0 1 -2.5 2.5 h-9 a2.5 2.5 0 0 1 -2.5 -2.5 v-7 h-7 A2.5 2.5 0 0 1 7.5 26 v-4 a2.5 2.5 0 0 1 2.5 -2.5 h7 v-7 A2.5 2.5 0 0 1 19.5 10 Z" fill="' + p.fg + '"/>'; } },
      { name: 'Cross & Heart', note: 'Medicine and kindness in one mark.',
        draw: function (p) { return '<path d="M19.5 10 h9 a2.5 2.5 0 0 1 2.5 2.5 v7 h7 a2.5 2.5 0 0 1 2.5 2.5 v4 a2.5 2.5 0 0 1 -2.5 2.5 h-7 v7 a2.5 2.5 0 0 1 -2.5 2.5 h-9 a2.5 2.5 0 0 1 -2.5 -2.5 v-7 h-7 A2.5 2.5 0 0 1 7.5 26 v-4 a2.5 2.5 0 0 1 2.5 -2.5 h7 v-7 A2.5 2.5 0 0 1 19.5 10 Z" fill="' + p.fg + '"/>' + heart(24, 24.5, 11, p.ac); } },
      { name: 'Gum Leaf', note: 'Australian, natural, gentle — health grown from home soil.',
        draw: function (p) { return leaf(24, 24, 7.5, 15, 28, p.fg) + '<path d="M18 36 Q24 26 30 12" fill="none" stroke="' + p.ac + '" stroke-width="2" stroke-linecap="round"/>'; } },
      { name: 'Twin Leaves', note: 'Balance and renewal — body and mind cared for together.',
        draw: function (p) { return leaf(17.5, 26, 5.5, 12, 30, p.fg) + leaf(30.5, 26, 5.5, 12, -30, p.ac) + '<path d="M24 38 v-14" stroke="' + p.fg + '" stroke-width="2.2" stroke-linecap="round"/>'; } },
      { name: 'Tree of Life', note: 'Growth, roots and shelter across every stage of life.',
        draw: function (p) { return '<path d="M24 40 V22 M24 28 l-6 -6 M24 25 l6 -6" stroke="' + p.fg + '" stroke-width="2.8" stroke-linecap="round"/><circle cx="24" cy="14" r="6" fill="' + p.ac + '"/><circle cx="14.5" cy="19" r="4.6" fill="' + p.fg + '"/><circle cx="33.5" cy="19" r="4.6" fill="' + p.fg + '"/>'; } },
      { name: 'Lotus', note: 'Calm and dignity — wellbeing of the whole person.',
        draw: function (p) { return leaf(24, 20, 5, 10, 0, p.fg) + leaf(15.5, 24, 4.5, 9, 42, p.ac) + leaf(32.5, 24, 4.5, 9, -42, p.ac) + '<path d="M12 33 q12 7 24 0" fill="none" stroke="' + p.fg + '" stroke-width="2.6" stroke-linecap="round"/>'; } },
      { name: 'Sunrise', note: 'A new day — hope, energy and better health each morning.',
        draw: function (p) { return '<path d="M13 28 a11 11 0 0 1 22 0 Z" fill="' + p.fg + '"/><path d="M24 9 v4.5 M11.5 14 l3.2 3.2 M36.5 14 l-3.2 3.2 M6.5 24.5 h4.5 M37 24.5 h4.5" stroke="' + p.fg + '" stroke-width="2.4" stroke-linecap="round"/><path d="M9 33.5 h30 M14 38.5 h20" stroke="' + p.ac + '" stroke-width="2.4" stroke-linecap="round"/>'; } },
      { name: 'Drop of Life', note: 'The essential drop — hydration, blood, life itself.',
        draw: function (p) { return '<path d="M24 8 C30 17 34 22 34 28.5 a10 10 0 0 1 -20 0 C14 22 18 17 24 8 Z" fill="' + p.fg + '"/>' + heart(24, 28, 9, p.bg); } },
      { name: 'Shield of Care', note: 'Protection and safety — a heart kept safe.',
        draw: function (p) { return '<path d="M24 8 C28 10.5 32.5 11.5 36.5 11.8 V24 C36.5 32 31 37 24 40 C17 37 11.5 32 11.5 24 V11.8 C15.5 11.5 20 10.5 24 8 Z" fill="none" stroke="' + p.fg + '" stroke-width="2.6" stroke-linejoin="round"/>' + heart(24, 23.5, 13, p.ac); } },
      { name: 'Heart at Home', note: 'Care where people most want it — at home.',
        draw: function (p) { return '<path d="M10 22 L24 10 L38 22 M13.5 19.5 V37 H34.5 V19.5" fill="none" stroke="' + p.fg + '" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>' + heart(24, 27.5, 11, p.ac); } },
      { name: 'Helping Hand', note: 'An open palm offering a heart — help, freely given.',
        draw: function (p) { return heart(24, 14.5, 12, p.ac) + '<path d="M13 27 h22 M13 27 v6 a7 7 0 0 0 7 7 h8 a7 7 0 0 0 7 -7 v-6" fill="none" stroke="' + p.fg + '" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 27 v-4 M24 27 v-5 M30 27 v-4" stroke="' + p.fg + '" stroke-width="2.8" stroke-linecap="round"/>'; } },
      { name: 'Monogram A', note: 'A confident "A" with a heartbeat crossbar.',
        draw: function (p) { return '<path d="M13 38 L24 12 L35 38" fill="none" stroke="' + p.fg + '" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/>' + pulse(16.5, 29.5, 15, p.ac); } },
      { name: 'Continuum', note: 'An unbroken loop — care that never drops the thread.',
        draw: function (p) { return '<path d="M24 24 C20 17 10 17 10 24 C10 31 20 31 24 24 C28 17 38 17 38 24 C38 31 28 31 24 24 Z" fill="none" stroke="' + p.fg + '" stroke-width="3" stroke-linejoin="round"/>' + heart(24, 24, 8, p.ac); } },
    ];

    function badge(p, inner, size) {
      var ring = p.ring ? 'stroke="' + p.ring + '" stroke-width="2.5"' : '';
      return '<svg class="' + (size >= 48 ? 'mark' : 'mini') + '" viewBox="0 0 48 48" width="' + size + '" height="' + size + '" aria-hidden="true">' +
        '<circle cx="24" cy="24" r="' + (p.ring ? 21.5 : 23) + '" fill="' + p.bg + '" ' + ring + '/>' + inner + '</svg>';
    }

    var legend = document.getElementById('legend');
    if (legend) legend.innerHTML = PALETTES.map(function (p) {
      return '<span><i style="background:' + p.bg + ';' + (p.ring ? 'border:2px solid ' + p.ring : '') + '"></i>' + p.key + ' · ' + p.name + '</span>';
    }).join('');

    var html = '';
    var n = 0;
    MARKS.forEach(function (m, mi) {
      html += '<h2 class="brand-family">' + m.name + ' <small>concept ' + (mi + 1) + ' of 20</small></h2>' +
              '<p class="brand-note">' + m.note + '</p><div class="brand-grid">';
      PALETTES.forEach(function (p) {
        n++;
        var inner = m.draw(p);
        html += '<div class="brand-card"><span class="num">No. ' + n + '</span>' +
          badge(p, inner, 84) +
          '<div class="brand-tab">' + badge(p, inner, 16) + '<span>Astro Care</span><span class="x">×</span></div>' +
          '<span class="cw">' + m.name + ' · ' + p.name + '</span></div>';
      });
      html += '</div>';
    });
    var gallery = document.getElementById('gallery');
    if (gallery) gallery.innerHTML = html;
  })();
</script>
