---
import '../styles/global.css';
const services = [
  ['Clinical & nursing care', 'Wound care, medication, health checks & recovery — by registered nurses.', '/media/poster-clinical.jpg'],
  ['Personal care', 'A gentle hand with showering, dressing and getting ready for the day.', '/media/loop-personal.jpg'],
  ['Allied health & therapy', 'Physio, OT and exercise to keep you strong, steady and moving well.', '/media/loop-allied.jpg'],
  ['Domestic assistance', 'Cleaning, laundry and light gardening — home kept safe and lovely.', '/media/poster-domestic.jpg'],
  ['Meal preparation', 'Fresh meals cooked your way, with good company while they’re made.', '/media/poster-meals.jpg'],
  ['Social support & company', 'Friendly visits, outings and someone to share a cuppa and a laugh.', '/media/poster-social.jpg'],
  ['Transport & getting out', 'Lifts to appointments, the shops or a favourite spot — company along the way.', '/media/loop-transport.jpg'],
  ['Respite & overnight care', 'A trusted hand so family carers can rest — hours or overnight.', '/media/loop-respite.jpg'],
];
const steps = [
  ['01', 'Say hello', 'Chat with us online or leave your number — no obligation.'],
  ['02', 'We sort the funding', 'We guide you through My Aged Care and handle the paperwork with you.'],
  ['03', 'Care begins at home', 'Your support workers arrive when you want them — and it flexes as needs change.'],
];
const funding = [
  ['Support at Home', 'Most people start here', 'The government program for care at home — funded on your assessed needs, from about $11,000 to $78,000 a year.'],
  ['CHSP', 'Entry-level help', 'A little help — cleaning, meals or transport — with a small contribution per service.'],
  ['Private care', 'No waiting', 'Start straight away from $65/hour and switch to government funding once approved.'],
];
const faqs = [
  ['Who is eligible for funded care?', 'Generally Australians 65+ (50+ for First Nations people) who need help to keep living at home. A free My Aged Care assessment confirms it — we help you arrange it.'],
  ['How much will it cost us?', 'The government pays the large majority for most people. Our fees are 15% care + 10% package management, under the caps, all published.'],
  ['How quickly can care start?', 'Privately within days; government-funded depends on the queue. Many start privately and switch when funding is approved.'],
  ['Where do you operate?', 'Right across Melbourne — inner suburbs to the outer ring.'],
];
---
<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><meta name="robots" content="noindex" />
    <title>Astro Care — Glass concept (full)</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@500;600;700&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      :root { --g-ink:#223243; --g-mut:#5b6b7b; --g-euca:#0C6291; --g-line:rgba(255,255,255,0.55); }
      * { box-sizing:border-box; }
      body { margin:0; color:var(--g-ink); font-family:'Instrument Sans',sans-serif; background:linear-gradient(160deg,#dbe7f2 0%, #cdd8e8 40%, #e7dfe8 75%, #f0e6ee 100%); background-attachment:fixed; }
      h1,h2,h3 { font-family:'Schibsted Grotesk',sans-serif; letter-spacing:-0.02em; }
      body h1, body h2, body h3, body h4 { color:inherit; }
      .wrap { width:min(1160px,100%-3rem); margin-inline:auto; }
      .glass { background:rgba(255,255,255,0.4); backdrop-filter:blur(18px); border:1px solid rgba(255,255,255,0.6); box-shadow:0 20px 50px rgba(80,100,130,0.15); }
      .rise { opacity:0; transform:translateY(26px); transition:opacity .9s cubic-bezier(.16,1,.3,1), transform .9s cubic-bezier(.16,1,.3,1); }
      .rise.in { opacity:1; transform:none; }
      .g-btn { display:inline-flex; align-items:center; gap:.5rem; border-radius:999px; padding:.75rem 1.4rem; font-weight:700; font-size:.9rem; }
      .pill { display:inline-flex; align-items:center; gap:.4rem; border-radius:999px; padding:.35rem 1rem; font-size:.78rem; font-weight:700; }
      details { border-bottom:1px solid rgba(90,110,130,0.2); }
      summary { list-style:none; cursor:pointer; padding:1.1rem 0; display:flex; justify-content:space-between; gap:1rem; font-weight:700; font-family:'Schibsted Grotesk'; }
      summary::-webkit-details-marker { display:none; }
    </style>
  </head>
  <body>
    <div class="wrap" style="padding-top:1rem;">
      <header class="glass rise in" style="position:sticky; top:1rem; z-index:50; border-radius:999px; display:flex; align-items:center; justify-content:space-between; padding:.6rem 1rem .6rem 1.3rem;">
        <a href="/" style="display:flex; align-items:center; gap:.5rem; color:var(--g-ink); text-decoration:none; font-weight:700; font-family:'Schibsted Grotesk';">
          <svg width="28" height="28" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" fill="#0C6291"/><path d="M13 38 L24 12 L35 38" stroke="#fff" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M16.5 29.5 h3.3 l1.65 -3.9 l2.4 7.8 l2.1 -5.1 l1.2 1.2 h4.35" stroke="#F2B33D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>Astro Care</a>
        <nav style="display:flex; gap:1.6rem; font-size:.85rem; font-weight:600; color:#33465a;" class="hide-sm"><a href="#services" style="color:inherit;text-decoration:none;">Services</a><a href="#how" style="color:inherit;text-decoration:none;">How it works</a><a href="#funding" style="color:inherit;text-decoration:none;">Funding</a><a href="#faq" style="color:inherit;text-decoration:none;">FAQ</a></nav>
        <a href="#contact" class="g-btn" style="background:rgba(28,43,54,0.9); color:#fff;">Book a callback ↗</a>
      </header>
    </div>

    <!-- HERO -->
    <section class="wrap" style="padding:1.5rem 0 2.5rem;">
      <div style="position:relative; border-radius:2rem; overflow:hidden; min-height:460px; display:flex; align-items:center; justify-content:center; text-align:center;">
        <img src="/media/loop-transport.jpg" alt="" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; filter:saturate(0.92) brightness(1.04);" />
        <div style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(220,231,242,0.5), rgba(231,223,232,0.4));"></div>
        <div class="glass" style="position:relative; margin:1.2rem; border-radius:1.6rem; padding:3rem 2rem;">
          <span class="pill" style="background:rgba(255,255,255,0.7); color:var(--g-euca);">✦ Care that fits your life</span>
          <h1 style="margin:1rem 0 0; font-weight:600; font-size:clamp(2.4rem,6vw,4.4rem); line-height:1.02; color:#223243;">Care that flows<br/>around you.</h1>
          <p style="margin:1rem auto 0; max-width:44ch; color:#46596b; font-size:1rem;">Nursing, personal care, meals, cleaning and good company — at home, across Melbourne, funded for most over 65.</p>
          <div style="display:flex; gap:.8rem; justify-content:center; margin-top:1.6rem; flex-wrap:wrap;">
            <a href="#contact" class="g-btn" style="background:var(--g-euca); color:#fff;">Get started ↗</a>
            <a href="#services" class="g-btn" style="background:rgba(255,255,255,0.7); color:var(--g-ink);">Our services</a>
          </div>
        </div>
      </div>
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-top:1.4rem;">
        {[['1 day','to your callback'],['24/7','care day & night'],['$0','lock-in contracts'],['100%','fee transparency']].map(([n,l])=>(
          <div class="glass rise" style="border-radius:1.2rem; padding:1.2rem; text-align:center;"><p style="margin:0; font-size:1.8rem; font-weight:700; font-family:'Schibsted Grotesk'; color:var(--g-euca);">{n}</p><p style="margin:.2rem 0 0; color:var(--g-mut); font-size:.8rem;">{l}</p></div>
        ))}
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="wrap" style="padding:2.5rem 0;">
      <p class="rise" style="color:var(--g-euca); font-weight:700; letter-spacing:.14em; text-transform:uppercase; font-size:.78rem; margin:0;">What we do</p>
      <h2 class="rise" style="margin:.4rem 0 2rem; font-size:clamp(1.9rem,4vw,2.9rem); color:#223243;">Everything under one gentle roof</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(250px,1fr)); gap:1.2rem;">
        {services.map(([t,d,img])=>(
          <article class="glass rise" style="border-radius:1.2rem; overflow:hidden;">
            <div style="aspect-ratio:16/10; overflow:hidden;"><img src={img} alt="" style="width:100%; height:100%; object-fit:cover;"/></div>
            <div style="padding:1.2rem;"><h3 style="margin:0; font-size:1.1rem; color:#223243;">{t}</h3><p style="margin:.5rem 0 0; color:var(--g-mut); font-size:.9rem;">{d}</p></div>
          </article>
        ))}
      </div>
    </section>

    <!-- HOW -->
    <section id="how" class="wrap" style="padding:2.5rem 0;">
      <p class="rise" style="color:var(--g-euca); font-weight:700; letter-spacing:.14em; text-transform:uppercase; font-size:.78rem; margin:0;">Getting started</p>
      <h2 class="rise" style="margin:.4rem 0 2rem; font-size:clamp(1.9rem,4vw,2.9rem); color:#223243;">Three easy steps</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:1.2rem;">
        {steps.map(([n,t,d])=>(
          <div class="glass rise" style="border-radius:1.2rem; padding:1.6rem;"><p style="margin:0; font-size:2.4rem; font-weight:700; color:rgba(12,98,145,0.35); font-family:'Schibsted Grotesk';">{n}</p><h3 style="margin:.3rem 0 .4rem; font-size:1.2rem; color:#223243;">{t}</h3><p style="margin:0; color:var(--g-mut); font-size:.92rem;">{d}</p></div>
        ))}
      </div>
    </section>

    <!-- FUNDING -->
    <section id="funding" class="wrap" style="padding:2.5rem 0;">
      <p class="rise" style="color:var(--g-euca); font-weight:700; letter-spacing:.14em; text-transform:uppercase; font-size:.78rem; margin:0;">Funding</p>
      <h2 class="rise" style="margin:.4rem 0 2rem; font-size:clamp(1.9rem,4vw,2.9rem); color:#223243;">The government pays for most of it</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.2rem;">
        {funding.map(([t,tag,d])=>(
          <div class="glass rise" style="border-radius:1.2rem; padding:1.6rem;"><span class="pill" style="background:rgba(12,98,145,0.12); color:var(--g-euca);">{tag}</span><h3 style="margin:.6rem 0 .5rem; font-size:1.25rem; color:#223243;">{t}</h3><p style="margin:0; color:var(--g-mut); font-size:.92rem;">{d}</p></div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="wrap" style="padding:2.5rem 0; max-width:840px;">
      <h2 class="rise" style="margin:0 0 1.4rem; font-size:clamp(1.9rem,4vw,2.7rem); color:#223243;">The things families ask first</h2>
      <div class="glass rise" style="border-radius:1.4rem; padding:.5rem 1.6rem;">
        {faqs.map(([q,a])=>(
          <details><summary>{q}<span style="color:var(--g-euca);">+</span></summary><p style="margin:0 0 1.1rem; color:var(--g-mut); font-size:.94rem;">{a}</p></details>
        ))}
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="wrap" style="padding:3rem 0 3.5rem;">
      <div class="glass rise" style="border-radius:1.6rem; padding:3rem 2rem; text-align:center;">
        <h2 style="margin:0; font-size:clamp(2rem,4.5vw,3rem); color:#223243;">Let’s have a chat</h2>
        <p style="margin:.9rem auto 1.8rem; max-width:40ch; color:var(--g-mut);">No pressure, no obligation — just honest answers about the help you can get. We ring back within one business day.</p>
        <div style="display:flex; gap:.8rem; justify-content:center; flex-wrap:wrap;">
          <a href="tel:+611800278762" class="g-btn" style="background:var(--g-euca); color:#fff;">1800 ASTRO</a>
          <a href="mailto:info@astrocare.com.au" class="g-btn" style="background:rgba(255,255,255,0.75); color:var(--g-ink);">Email us</a>
        </div>
      </div>
    </section>

    <footer style="padding:2rem 0; color:var(--g-mut); font-size:.85rem;">
      <div class="wrap" style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:1rem;"><span>© 2026 Astro Care Group Pty Ltd · ABN 99 700 192 981</span><span>Aged care at home · All of Melbourne</span></div>
    </footer>

    <script is:inline>
      var io = new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:0,rootMargin:'0px 0px -8% 0px'});
      document.querySelectorAll('.rise').forEach(function(el){io.observe(el)});
      var s=document.createElement('style'); s.textContent='@media(max-width:760px){section[style*="repeat(4"]{grid-template-columns:repeat(2,1fr)!important}}@media(max-width:640px){.hide-sm{display:none!important}}'; document.head.appendChild(s);
    </script>
  </body>
</html>
