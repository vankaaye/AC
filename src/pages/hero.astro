---
/**
 * hero.astro — astrocare.com.au/hero
 * ------------------------------------------------------------------
 * Hero background chooser: 30 numbered image options (H1–H30), each
 * previewed exactly as a homepage hero — wide crop, soft dark overlay
 * and the real headline on top. Pick by number.
 * ------------------------------------------------------------------
 */
import Layout from '../layouts/Layout.astro';

const options: [string, string, string][] = [
  ['H1', '1543333995-a78aea2eee50', 'Golden afternoon stroll'],
  ['H2', '1581579438747-1dc8d17bbce4', 'Cooking at home'],
  ['H3', '1584515933487-779824d29309', 'Caring hands'],
  ['H4', '1516734212186-a967f81ad0d7', 'Therapy dog'],
  ['H5', '1493663284031-b7e3aefcae8e', 'Cosy lounge'],
  ['H6', '1522708323590-d24dbb6b0267', 'Bright, airy home'],
  ['H7', '1544928147-79a2dbc1f389', 'Craft afternoon'],
  ['H8', '1585320806297-9794b3e4eeae', 'Rose garden path'],
  ['H9', '1600585154340-be6161a56a0c', 'Home at dusk'],
  ['H10', '1576765608866-5b51046452be', 'Nurse with client'],
  ['H11', '1478061653917-455ba7f4a541', 'Family laughter'],
  ['H12', '1454418747937-bd95bb945625', 'Quiet lakeside read'],
  ['H13', '1450778869180-41d0601e046e', 'Dog & cat nap'],
  ['H14', '1548199973-03cce0bbc87b', 'Happy dogs'],
  ['H15', '1507146426996-ef05306b995a', 'Puppy eyes'],
  ['H16', '1464226184884-fa280b87c399', 'Garden harvest'],
  ['H17', '1495214783159-3503fd1b572d', 'Fresh breakfast'],
  ['H18', '1470071459604-3b5ec3a7fe05', 'Morning headland'],
  ['H19', '1500382017468-9049fed747ef', 'Golden paddock sunrise'],
  ['H20', '1490750967868-88aa4486c946', 'Wildflowers'],
  ['H21', '1505455184862-554165e5f6ba', 'Flower in open hands'],
  ['H22', '1544367567-0f2fcb009e0b', 'Sunset stretch'],
  ['H23', '1447752875215-b2761acb3c5d', 'Forest bridge'],
  ['H24', '1499728603263-13726abce5fd', 'Mindfulness'],
  ['H25', '1506126613408-eca07ce68773', 'Morning calm'],
  ['H26', '1559839734-2b71ea197ec2', 'Smiling nurse'],
  ['H27', '1594824476967-48c8b964273f', 'Carer portrait'],
  ['H28', '1612349317150-e413f6a5b16d', 'Doctor portrait'],
  ['H29', '1607746882042-944635dfe10e', 'Team member'],
  ['H30', '1444840535719-195841cb6e2b', "Grandkids' crafts"],
];
---

<Layout title="Astro Care — Hero Image Options" description="Choose the homepage hero background image (30 numbered options).">
  <section class="py-10 md:py-14" style="background: var(--bg-sand);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
      <p class="mb-2 text-lg font-extrabold uppercase tracking-widest" style="font-family: var(--font-head); color: var(--sun-deep);">
        Design studio
      </p>
      <h1 class="mb-4 text-3xl md:text-5xl">30 hero image options</h1>
      <p class="max-w-3xl text-xl" style="color: var(--tx-soft);">
        Each one is previewed exactly as it would look behind the homepage headline — with the soft
        dark overlay that keeps text readable. <strong>To choose, just tell us the H-number.</strong>
      </p>
    </div>
  </section>

  <section class="py-8 md:py-12" style="background: var(--bg);">
    <div class="mx-auto grid w-[min(1220px,100%-2.5rem)] gap-6">
      {
        options.map(([num, id, label]) => (
          <figure class="overflow-hidden rounded-3xl border-4 hc-border" style="border-color: var(--line); box-shadow: var(--shadow);">
            <div class="relative">
              <img
                src={`https://images.unsplash.com/photo-${id}?w=1600&h=640&fit=crop&q=80&auto=format`}
                alt={label}
                loading="lazy"
                class="aspect-[5/2] w-full object-cover"
                width="1600" height="640"
              />
              <div class="absolute inset-0" style="background: linear-gradient(100deg, rgba(20,28,24,0.62) 0%, rgba(20,28,24,0.28) 55%, transparent 100%);" aria-hidden="true"></div>
              <div class="absolute left-[5%] top-1/2 max-w-[70%] -translate-y-1/2 text-white">
                <p class="mb-1 text-sm font-extrabold uppercase tracking-widest opacity-90 md:text-lg" style="font-family: var(--font-head);">G'day! We're Astro Care.</p>
                <p class="text-2xl font-black leading-tight md:text-5xl" style="font-family: var(--font-head);">Live happily in your own home.</p>
              </div>
              <span class="absolute right-3 top-3 rounded-full px-4 py-1.5 text-lg font-black" style="background: var(--sun); color: var(--tx); font-family: var(--font-head);">{num}</span>
            </div>
            <figcaption class="flex items-center justify-between gap-3 px-5 py-3 text-lg font-bold" style="background: var(--bg-card);">
              {label}
              <span style="color: var(--tx-soft);">{num}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <section class="py-8" style="background: var(--bg-sand);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
      <div class="rounded-3xl border-l-8 p-6 text-xl" style="background: var(--bg-card); border-color: var(--sun); box-shadow: var(--shadow);">
        <p><strong>How to choose:</strong> tell us the number — e.g. "hero H19". We'll set it as the homepage background straight away.</p>
      </div>
    </div>
  </section>
</Layout>
