---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — Astro Care" noindex={true}>
  <section class="mx-auto flex min-h-[55vh] w-[min(720px,100%-2.5rem)] flex-col items-start justify-center py-20">
    <p class="mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">404</p>
    <h1 class="text-3xl md:text-4xl">That page isn’t here.</h1>
    <p class="mt-3 max-w-md text-base" style="color: var(--tx-soft);">
      The link may be old or mistyped. Everything you need is on our home page —
      services, funding help, fees and how to reach us.
    </p>
    <div class="mt-7 flex flex-wrap gap-3">
      <a href="/" class="btn-primary">Back to the home page</a>
      <a href="/#contact" class="btn-sun">Ask us to call you</a>
    </div>
  </section>
</Layout>
