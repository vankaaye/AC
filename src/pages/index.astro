---
/**
 * index.astro — Astro Care home page
 * ------------------------------------------------------------------
 * Lively, senior-first home page:
 *   Hero → compliance badges → quick help → services grid →
 *   "How to Access Funding" (HCP 1–4 & CHSP) → Pricing Calculator →
 *   family stories → contact/callback form.
 *
 * Every heading and paragraph carries the `readable` class so the
 * Accessibility Panel's Read Aloud mode can speak it on click.
 * No carousels, no hover menus, no fast motion anywhere.
 * ------------------------------------------------------------------
 */
import Layout from '../layouts/Layout.astro';
import PricingCalculator from '../components/PricingCalculator.astro';

const services = [
  {
    title: 'Clinical Care',
    photo: 'https://images.unsplash.com/photo-1584515933487-779824d29309?w=800&q=85&auto=format&fit=crop',
    alt: "A nurse gently holding an older person's hands",
    color: 'var(--blue)',
    soft: 'var(--blue-soft)',
    text: 'Registered nurses for wound care, medication, health checks and recovery after hospital — in the comfort of home.',
  },
  {
    title: 'Social Support',
    photo: 'https://images.unsplash.com/photo-1516734212186-a967f81ad0d7?w=800&q=85&auto=format&fit=crop',
    alt: 'A golden retriever getting a friendly pat',
    color: 'var(--sun-deep)',
    soft: 'var(--sun-soft)',
    text: 'Friendly visits, outings, a hand with the shopping, and someone lovely to share a cuppa and a laugh with.',
  },
  {
    title: 'Domestic Assistance',
    photo: 'https://images.unsplash.com/photo-1493663284031-b7e3aefcae8e?w=800&q=85&auto=format&fit=crop',
    alt: 'A bright, tidy and comfortable living room',
    color: 'var(--euca)',
    soft: 'var(--euca-soft)',
    text: 'Cleaning, laundry, gardening and small jobs around the house — done cheerfully, so home stays safe and lovely.',
  },
  {
    title: 'Meal Preparation',
    photo: 'https://images.unsplash.com/photo-1581579438747-1dc8d17bbce4?w=800&q=85&auto=format&fit=crop',
    alt: 'A senior lady preparing fresh food in her sunlit kitchen',
    color: 'var(--call)',
    soft: '#FAE7E0',
    text: "Tasty, healthy meals cooked in your kitchen just the way you like them — with company while they're made.",
  },
];

const stories = [
  {
    quote:
      "The staff didn't just care for Mum — they knew her. They knew she took her tea weak, loved Sinatra, and missed her roses. So they planted roses outside her window.",
    who: 'Helen, daughter of Margaret',
    tag: 'Home Care Package family',
  },
  {
    quote:
      "Dad swore he'd never accept help — now he greets his Astro Care visitors like old friends. Because that's what they've become.",
    who: 'David, son of Robert',
    tag: 'Home Care Package client',
  },
  {
    quote:
      'The fees were explained on one page, in plain English, before we signed anything. After two years of confusing brochures, that honesty won us over.',
    who: 'Priya, daughter of Anand',
    tag: 'CHSP client',
  },
];
---

<Layout>
  <!-- ============ HERO ============ -->
  <section
    class="py-14 md:py-20"
    style="background:
      radial-gradient(ellipse 60% 80% at 90% 0%, var(--sun-soft) 0%, transparent 65%),
      radial-gradient(ellipse 45% 60% at 0% 100%, var(--euca-soft) 0%, transparent 70%),
      var(--bg-sand);"
  >
    <div class="mx-auto grid w-[min(1220px,100%-2.5rem)] items-center gap-12 lg:grid-cols-[1.15fr_1fr]">
      <div>
        <p class="readable mb-3 text-2xl font-extrabold" style="font-family: var(--font-head); color: var(--sun-deep);">
          G'day! We're Astro Care.
        </p>
        <h1 class="readable mb-5 text-5xl md:text-6xl">
          Live happily in your <em class="not-italic" style="color: var(--euca);">own home</em>, with our gentle help.
        </h1>
        <p class="readable mb-8 max-w-[44ch] text-2xl" style="color: var(--tx-soft);">
          We help Australian seniors with nursing, cleaning, meals and good company — funded by the
          government wherever possible. One friendly phone call is all it takes to start.
        </p>
        <div class="mb-9 flex flex-wrap gap-4">
          <a href="tel:+611800278762" class="btn-sun hc-border !text-2xl !px-9 !py-5">
            <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call Us Now
          </a>
          <a href="#funding" class="btn-primary hc-border !text-2xl !px-9 !py-5">How Funding Works</a>
        </div>

        <!-- Compliance badges -->
        <ul class="flex flex-wrap gap-3" aria-label="Our accreditations">
          {
            [
              ['My Aged Care', 'Approved Provider'],
              ['NDIS', 'Registered Provider'],
              ['Quality Standards', 'Aged Care Compliant'],
            ].map(([strong, rest]) => (
              <li
                class="flex min-h-14 items-center gap-3 rounded-2xl border-4 px-4 py-2"
                style="background: var(--bg-card); border-color: var(--euca);"
              >
                <svg class="h-9 w-9 shrink-0" style="color: var(--euca);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" /><path d="m9 12 2 2 4-4" />
                </svg>
                <span class="flex flex-col text-lg leading-tight" style="color: var(--tx-soft);">
                  <strong style="font-family: var(--font-head); color: var(--tx);">{strong}</strong>
                  {rest}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative">
        <img
          src="https://images.unsplash.com/photo-1543333995-a78aea2eee50?w=1000&q=85&auto=format&fit=crop"
          alt="A happy senior enjoying a sunlit afternoon walk in her garden"
          class="aspect-[4/4.2] w-full rounded-[28px] border-8 object-cover"
          style="border-color: var(--bg-card); box-shadow: var(--shadow);"
          width="1000" height="1050"
        />
        <p
          class="readable absolute -left-3 bottom-7 flex max-w-[90%] items-center gap-3 rounded-2xl px-5 py-4 text-xl"
          style="background: var(--bg-card); box-shadow: var(--shadow);"
        >
          <svg class="h-9 w-9 shrink-0" style="color: var(--sun);" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3c.9 4.2 3.3 6.6 7.5 7.5-4.2.9-6.6 3.3-7.5 7.5-.9-4.2-3.3-6.6-7.5-7.5 4.2-.9 6.6-3.3 7.5-7.5z"/></svg>
          Rated <strong>4.9 out of 5</strong> by the families we care for
        </p>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section id="services" class="py-16" style="background: var(--bg);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
      <h2 class="readable mb-3 text-4xl md:text-5xl">Our services, <em class="not-italic" style="color: var(--euca);">your way</em></h2>
      <p class="readable mb-10 max-w-3xl text-xl" style="color: var(--tx-soft);">
        Pick as much or as little help as you like. We'll fit around your routine — never the other way round.
      </p>
      <div class="grid gap-7 md:grid-cols-2">
        {
          services.map((s) => (
            <article
              class="grid overflow-hidden rounded-3xl border-4 hc-border transition-transform hover:-translate-y-1 sm:grid-cols-[42%_58%]"
              style="background: var(--bg-card); border-color: var(--line); box-shadow: var(--shadow);"
            >
              <img src={s.photo} alt={s.alt} class="h-full min-h-52 w-full object-cover" width="800" height="800" loading="lazy" />
              <div class="flex flex-col items-start p-7">
                <span class="mb-3 inline-flex rounded-2xl px-4 py-2 text-lg font-black" style={`background:${s.soft}; color:${s.color}; font-family: var(--font-head);`}>
                  {s.title}
                </span>
                <p class="readable grow text-xl" style="color: var(--tx-soft);">{s.text}</p>
                <a
                  href="#contact"
                  class="mt-4 flex min-h-14 items-center gap-2 border-b-4 text-xl font-extrabold"
                  style={`border-color: var(--sun); color: var(--blue); font-family: var(--font-head);`}
                >
                  Ask about {s.title.toLowerCase()}
                  <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ HOW TO ACCESS FUNDING ============ -->
  <section id="funding" class="py-16" style="background: var(--euca-soft);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
      <h2 class="readable mb-3 text-4xl md:text-5xl">How to access funding — <em class="not-italic" style="color: var(--euca);">in plain English</em></h2>
      <p class="readable mb-10 max-w-3xl text-xl" style="color: var(--tx-soft);">
        The Australian Government helps pay for care at home in two main ways. Don't worry about
        choosing — call us and we'll work out which suits you, then handle the paperwork together.
      </p>

      <div class="grid gap-7 lg:grid-cols-2">
        <!-- HCP pathway -->
        <div class="rounded-3xl border-t-[12px] p-8" style="background: var(--bg-card); border-color: var(--euca); box-shadow: var(--shadow);">
          <p class="mb-2 inline-block rounded-full px-4 py-1 text-lg font-black uppercase tracking-wide" style="background: var(--sun); font-family: var(--font-head);">Option 1</p>
          <h3 class="readable text-3xl mb-2">Home Care Package <span class="text-2xl" style="color: var(--tx-soft);">(HCP, Levels 1–4)</span></h3>
          <p class="readable mb-6 text-xl" style="color: var(--tx-soft);">
            Best for <strong style="color: var(--tx);">regular or growing help</strong> — from a few visits a week (Level 1) to daily support (Level 4).
          </p>
          <ol class="grid gap-5">
            {
              [
                ['Call My Aged Care on 1800 200 422 — or call us first', "and we'll help you register. It takes about 10 minutes."],
                ['Have a free assessment at home.', 'A friendly assessor visits and works out your package level (1 to 4).'],
                ['Choose Astro Care as your provider.', 'We plan your care with you and manage the budget openly.'],
                ['Your care begins.', 'The same friendly faces, week after week — reviewed with you as needs change.'],
              ].map(([strong, rest], i) => (
                <li class="flex items-start gap-4 text-xl">
                  <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-2xl font-black text-white" style="background: var(--euca); font-family: var(--font-head);">{i + 1}</span>
                  <p class="readable" style="color: var(--tx-soft);"><strong style="color: var(--tx);">{strong}</strong> {rest}</p>
                </li>
              ))
            }
          </ol>
        </div>

        <!-- CHSP pathway -->
        <div class="rounded-3xl border-t-[12px] p-8" style="background: var(--bg-card); border-color: var(--blue); box-shadow: var(--shadow);">
          <p class="mb-2 inline-block rounded-full px-4 py-1 text-lg font-black uppercase tracking-wide" style="background: var(--sun); font-family: var(--font-head);">Option 2</p>
          <h3 class="readable text-3xl mb-2">Commonwealth Home Support <span class="text-2xl" style="color: var(--tx-soft);">(CHSP)</span></h3>
          <p class="readable mb-6 text-xl" style="color: var(--tx-soft);">
            Best for <strong style="color: var(--tx);">a little help to stay independent</strong> — like cleaning, meals or transport.
          </p>
          <ol class="grid gap-5">
            {
              [
                ['Call us or My Aged Care.', "We'll check you're eligible (most people 65+ are)."],
                ['Have a quick phone or home chat', 'with an assessor to agree on the services you would like.'],
                ['Services start — often within days.', 'You pay only a small contribution; the government covers the rest.'],
              ].map(([strong, rest], i) => (
                <li class="flex items-start gap-4 text-xl">
                  <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full text-2xl font-black text-white" style="background: var(--blue); font-family: var(--font-head);">{i + 1}</span>
                  <p class="readable" style="color: var(--tx-soft);"><strong style="color: var(--tx);">{strong}</strong> {rest}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap items-center justify-between gap-5 rounded-3xl p-7" style="background: var(--bg-card); box-shadow: var(--shadow);">
        <p class="readable text-2xl"><strong>Feeling unsure?</strong> That's completely normal — the system confuses everyone. One call sorts it out.</p>
        <a href="tel:+611800278762" class="btn-sun hc-border !text-2xl">Call 1800 ASTRO (278 762)</a>
      </div>
    </div>
  </section>

  <!-- ============ PRICING & FEE TRANSPARENCY CALCULATOR ============ -->
  <PricingCalculator />

  <!-- ============ FAMILY STORIES ============ -->
  <section id="stories" class="py-16" style="background: var(--bg);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
      <h2 class="readable mb-10 text-center text-4xl md:text-5xl">Don't take <em class="not-italic" style="color: var(--euca);">our</em> word for it</h2>
      <div class="grid gap-7 md:grid-cols-3">
        {
          stories.map((s) => (
            <figure class="flex flex-col rounded-3xl border-4 hc-border p-7" style="background: var(--bg-card); border-color: var(--line); box-shadow: var(--shadow);">
              <div class="mb-4 flex gap-1" style="color: var(--sun);" aria-label="Five stars">
                {[...Array(5)].map(() => (
                  <svg class="h-7 w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.26L21.5 9.3l-4.75 4.5 1.15 6.7L12 17.25 6.1 20.5l1.15-6.7L2.5 9.3l6.6-1.04z"/></svg>
                ))}
              </div>
              <blockquote class="readable grow text-xl" style="color: var(--tx-soft);">"{s.quote}"</blockquote>
              <figcaption class="mt-5 text-lg">
                <strong style="font-family: var(--font-head); color: var(--euca);">{s.who}</strong>
                <br /><span style="color: var(--tx-soft);">{s.tag}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ CONTACT / CALLBACK ============ -->
  <section id="contact" class="py-16" style="background: var(--sun-soft);">
    <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
      <h2 class="readable mb-3 text-center text-4xl md:text-5xl">Let's have a <em class="not-italic" style="color: var(--euca);">friendly chat</em></h2>
      <p class="readable mx-auto mb-10 max-w-2xl text-center text-xl" style="color: var(--tx-soft);">
        No obligation, no pressure — just honest answers about the help you can get.
      </p>
      <div class="grid gap-7 lg:grid-cols-2">
        <div class="rounded-3xl p-8" style="background: var(--bg-card); box-shadow: var(--shadow);">
          <h3 class="readable text-3xl mb-5">The quickest way: pick up the phone</h3>
          <a href="tel:+611800278762" class="btn-primary hc-border w-full !justify-start !text-3xl !py-6 mb-5">
            <svg class="h-11 w-11 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>1800 ASTRO<br /><small class="text-xl font-bold opacity-90">(1800 278 762)</small></span>
          </a>
          <p class="readable text-xl mb-4" style="color: var(--tx-soft);">Monday to Friday, 8am – 6pm<br />Saturday, 9am – 4pm</p>
          <p class="readable text-xl" style="color: var(--tx-soft);">
            Prefer to write? <a href="mailto:info@astrocare.com.au" class="font-bold underline underline-offset-4" style="color: var(--blue);">info@astrocare.com.au</a>
          </p>
        </div>

        <form id="callbackForm" class="rounded-3xl p-8" style="background: var(--bg-card); box-shadow: var(--shadow);" novalidate>
          <h3 class="readable text-3xl mb-5">Or ask us to call you</h3>
          <label class="mb-5 block text-xl font-extrabold" style="font-family: var(--font-head);">
            Your name
            <input type="text" name="name" required autocomplete="name" placeholder="e.g. Margaret Smith"
              class="mt-2 block min-h-16 w-full rounded-2xl border-4 px-5 text-xl"
              style="border-color: var(--line); background: var(--bg); font-family: var(--font-body);" />
          </label>
          <label class="mb-5 block text-xl font-extrabold" style="font-family: var(--font-head);">
            Your phone number
            <input type="tel" name="phone" required autocomplete="tel" placeholder="e.g. 0412 345 678"
              class="mt-2 block min-h-16 w-full rounded-2xl border-4 px-5 text-xl"
              style="border-color: var(--line); background: var(--bg); font-family: var(--font-body);" />
          </label>
          <label class="mb-6 block text-xl font-extrabold" style="font-family: var(--font-head);">
            What would you like help with?
            <select name="careType" required
              class="mt-2 block min-h-16 w-full rounded-2xl border-4 px-5 text-xl"
              style="border-color: var(--line); background: var(--bg); font-family: var(--font-body);">
              <option value="" selected disabled>Please choose one…</option>
              <option>Help around the house</option>
              <option>Nursing / clinical care</option>
              <option>Meals</option>
              <option>Company and outings</option>
              <option>Getting started with My Aged Care</option>
              <option>I'm not sure — please guide me</option>
            </select>
          </label>
          <button type="submit" class="btn-primary hc-border w-full !text-2xl">Please call me back</button>
          <p class="mt-3 text-center text-lg" style="color: var(--tx-soft);">We'll ring you within one business day. Your details stay private.</p>
          <div id="formSuccess" class="mt-4 hidden rounded-2xl border-4 p-5 text-center text-xl" style="background: var(--euca-soft); border-color: var(--euca); color: var(--euca-deep);" role="status">
            <strong>Thank you — message received!</strong><br />A friendly team member will call you within one business day.
          </div>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    /* Callback form: friendly local confirmation (hook up a backend later). */
    var form = document.getElementById('callbackForm');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = form.querySelector('button[type="submit"]');
        btn.textContent = 'Sending…';
        btn.disabled = true;
        setTimeout(function () {
          document.getElementById('formSuccess').classList.remove('hidden');
          btn.style.display = 'none';
          form.querySelectorAll('input, select').forEach(function (el) { el.value = ''; });
        }, 800);
      });
    }
  </script>
</Layout>
