  })} />

  <script is:inline>
    /* Hero parallax: video drifts slower than the page. */
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var v = document.querySelector('section video[data-ambient]');
      if (!v) return;
      var ticking = false;
      window.addEventListener('scroll', function () {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          var y = window.scrollY;
          if (y < window.innerHeight * 1.2) v.style.transform = 'translateY(' + y * 0.22 + 'px) scale(1.08)';
          ticking = false;
        });
      }, { passive: true });
    })();

    /* Count-up numbers when the stats band scrolls into view. */
    (function () {
      var els = document.querySelectorAll('[data-countup]');
      if (!els.length) return;
      var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (!e.isIntersecting) return;
          io.unobserve(e.target);
          var target = parseInt(e.target.getAttribute('data-countup'), 10);
          if (reduced || target === 0) { e.target.textContent = String(target); return; }
          var t0 = performance.now();
          var dur = 1100;
          (function tick(now) {
            var p = Math.min(1, (now - t0) / dur);
            e.target.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
            if (p < 1) requestAnimationFrame(tick);
          })(t0);
        });
      }, { threshold: 0.6 });
      els.forEach(function (el) { io.observe(el); });
    })();

    /* Scroll-linked media zoom: [data-zoom] wrappers ease their video
       from a gentle close-up to full frame as they travel up the screen. */
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var zooms = Array.from(document.querySelectorAll('[data-zoom]'));
      if (!zooms.length) return;
      var active = new Set();
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { e.isIntersecting ? active.add(e.target) : active.delete(e.target); });
      }, { rootMargin: '10% 0px' });
      zooms.forEach(function (el) { io.observe(el); });
      var ticking = false;
      function update() {
        active.forEach(function (el) {
          var r = el.getBoundingClientRect();
          var progress = 1 - Math.min(1, Math.max(0, (r.top + r.height * 0.5) / (window.innerHeight + r.height * 0.5)));
          var scale = 1.14 - 0.14 * Math.min(1, progress * 1.6);
          var media = el.firstElementChild;
          if (media) media.style.transform = 'scale(' + scale.toFixed(3) + ')';
        });
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      }, { passive: true });
      update();
    })();

    /* Hero video pause control (WCAG 2.2.2). */
    (function () {
      var v = document.querySelector('section video[data-ambient]');
      var b = document.getElementById('heroPause');
      if (!v || !b) return;
      b.addEventListener('click', function () {
        var paused = v.paused;
        if (paused) { v.play().catch(function () {}); } else { v.pause(); }
        b.setAttribute('aria-pressed', String(!paused ? true : false));
        b.setAttribute('aria-label', paused ? 'Pause background video' : 'Play background video');
        document.getElementById('heroPauseIcon').innerHTML = paused
          ? '<path d="M7 5h4v14H7zM13 5h4v14h-4z"/>'
          : '<path d="M8 5v14l11-7z"/>';
      });
    })();

    /* Funding cards: Stripe-style self-cycling spotlight — each card
       takes a turn in focus while the section is on screen. Pauses on
       hover/focus and respects reduced motion. */
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var grid = document.getElementById('fundGrid');
      if (!grid) return;
      var cards = Array.from(grid.querySelectorAll('.fund-card'));
      if (cards.length < 2) return;
      var idx = 0, timer = null;
      function tick() {
        cards.forEach(function (c, i) { c.classList.toggle('fund-on', i === idx); });
        idx = (idx + 1) % cards.length;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting && !timer) { tick(); timer = setInterval(tick, 3200); }
          else if (!e.isIntersecting && timer) { clearInterval(timer); timer = null; }
        });
      }, { threshold: 0.35 });
      io.observe(grid);
    })();

    /* "Ask our chat helper" buttons open the chat. The chat widget is
       rendered later in the body (in the layout), so resolve #openChat
       at click time — resolving it here would find nothing. */
    (function () {
      ['askFundingChat', 'askContactChat'].forEach(function (id) {
        var b = document.getElementById(id);
        if (b) b.addEventListener('click', function () {
          var open = document.getElementById('openChat');
          if (open) open.click();
        });
      });
    })();

    /* Callback form → emails via FormSubmit relay. */
    var form = document.getElementById('callbackForm');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (!form.reportValidity()) return;
        var btn = form.querySelector('button[type="submit"]');
        btn.textContent = 'Sending…';
        btn.disabled = true;
        var f = new FormData(form);
        /* TEMP: direct to Gopi's inbox — astrocare.com.au has no MX records
           yet, so info@ can't receive mail until GoDaddy email forwarding
           is set up. Address assembled at runtime to avoid scrapers. */
        var addr = ['gopi', 'ktechify.com'].join('@');
        fetch('https://formsubmit.co/ajax/' + addr, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            _subject: 'Callback request: ' + (f.get('name') || ''),
            _template: 'table',
            _honey: f.get('_honey') || '',
            Name: f.get('name'),
            Phone: f.get('phone'),
            'Help needed with': f.get('careType'),
            Page: location.href,
          }),
        })
          .then(function (r) { if (!r.ok) throw new Error('send failed'); return r.json(); })
          .then(function () {
            document.getElementById('formSuccess').classList.remove('hidden');
            btn.style.display = 'none';
            form.querySelectorAll('input, select').forEach(function (el) { el.value = ''; });
          })
          .catch(function () {
            document.getElementById('formError').classList.remove('hidden');
            btn.textContent = 'Please call me back';
            btn.disabled = false;
          });
      });
    }
  </script>
</Layout>
