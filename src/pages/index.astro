---
/**
 * index.astro — astrocare.com.au (design v2 "AU Modern")
 * ------------------------------------------------------------------
 * Full-bleed video hero, ambient care videos through the page,
 * scroll-reveal animations, refined type at normal sizes. Styled
 * after Australia's best care & government health sites.
 * Sections: hero → statement → services → how it works → funding
 * → fee calculator → why us → contact/callback.
 * ------------------------------------------------------------------
 */
import Layout from '../layouts/Layout.astro';
import PricingCalculator from '../components/PricingCalculator.astro';

const services = [
  {
    id: 'clinical',
    title: 'Clinical & nursing care',
    text: 'Registered nurses for wound care, medication, health checks and recovery after hospital — in the comfort of home.',
    video: '/media/loop-clinical.mp4',
    poster: '/media/poster-clinical.jpg',
    alt: 'A blood-pressure check during a home nursing visit',
  },
  {
    id: 'social',
    title: 'Social support & company',
    text: 'Friendly visits, outings, a hand with the shopping — and someone lovely to share a cuppa and a laugh with.',
    video: '/media/loop-social.mp4',
    poster: '/media/poster-social.jpg',
    alt: 'A support worker arriving to visit an older lady relaxing in her armchair',
  },
  {
    id: 'domestic',
    title: 'Domestic assistance',
    text: 'Cleaning, laundry, gardening and small jobs around the house — done cheerfully, so home stays safe and lovely.',
    video: '/media/loop-domestic.mp4',
    poster: '/media/poster-domestic.jpg',
    alt: 'A cheerful helper tidying a bright living room',
  },
  {
    id: 'meals',
    title: 'Meal preparation',
    text: 'Fresh, tasty meals cooked in your own kitchen, just the way you like them — with good company while they’re made.',
    video: '/media/loop-meals.mp4',
    poster: '/media/poster-meals.jpg',
    alt: 'A fresh home-cooked meal of vegetables being handed over',
  },
];

const steps = [
  ['Say hello', 'Chat with us online or leave your number — we’ll talk through what would genuinely help, no obligation.', '01'],
  ['We sort the funding', 'We guide you through My Aged Care and handle the paperwork with you. Most Australians over 65 qualify for government funding.', '02'],
  ['Care begins at home', 'Your support workers arrive when you want them — and everything flexes as your needs change.', '03'],
];

const funding = [
  {
    name: 'Support at Home',
    tag: 'Most people start here',
    text: 'The Australian Government’s program for care at home (replacing Home Care Packages). Funding is based on your assessed needs — from about $11,000 to $78,000 a year.',
    eg: 'What that looks like: a weekly clean at the lowest level, up to several visits every day — nursing, showering help and meals — at the highest.',
  },
  {
    name: 'CHSP',
    tag: 'Entry-level help',
    text: 'The Commonwealth Home Support Programme suits people who need a little help — cleaning, meals or transport — with a small contribution per service.',
    eg: 'What that looks like: a fortnightly clean, delivered meals, or a lift to appointments for a few dollars per service.',
  },
  {
    name: 'Private care',
    tag: 'No waiting',
    text: 'Start straight away and switch to government funding when it’s approved. Simple hourly rates, published up front.',
    eg: 'What that looks like: three hours of help a week starting tomorrow, from $65/hour — no paperwork to wait on.',
  },
];
---

<Layout>
  <!-- ============ FULL-BLEED VIDEO HERO ============ -->
  <section class="relative flex min-h-[78svh] items-end overflow-hidden" aria-label="Welcome">
    <video
      class="absolute inset-0 h-full w-full object-cover"
      src="/media/hero-1080.mp4"
      poster="/media/hero-1080-poster.jpg"
      muted loop playsinline autoplay preload="metadata"
      data-ambient
      aria-hidden="true"
    ></video>
    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(11,26,32,0.88) 0%, rgba(11,26,32,0.42) 50%, rgba(11,26,32,0.22) 100%), linear-gradient(100deg, rgba(11,26,32,0.35) 0%, transparent 55%);" aria-hidden="true"></div>

    <button
      id="heroPause"
      class="absolute bottom-4 right-4 z-10 flex h-9 w-9 items-center justify-center rounded-full text-white"
      style="background: rgba(15,30,40,0.55); backdrop-filter: blur(6px);"
      aria-label="Pause background video" aria-pressed="false"
    >
      <svg id="heroPauseIcon" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 5h4v14H7zM13 5h4v14h-4z"/></svg>
    </button>

    <div class="relative mx-auto w-[min(1280px,100%-2.5rem)] pb-12 pt-32 md:pb-16">
      <h1 class="hero-rise max-w-3xl text-4xl leading-[1.06] font-extrabold tracking-tight sm:text-5xl md:text-6xl" style="color: #fff; text-shadow: 0 2px 24px rgba(11,26,32,0.35);">
        Care at home,<br />done properly.
      </h1>
      <p class="hero-rise-2 mt-4 max-w-lg text-base text-white/85 md:text-lg">
        Nursing, everyday help and genuine company for older people across
        Melbourne — government-funded for most over 65.
      </p>
      <div class="hero-rise-3 mt-8 flex flex-wrap items-center gap-3">
        <a href="#contact" class="btn-primary !px-6 !py-3 !text-base" style="background: #fff; color: var(--euca);">Get started</a>
        <a href="#services" class="btn-ghost !px-6 !py-3 !text-base">Explore our services</a>
      </div>
      <ul class="hero-rise-3 mt-7 flex flex-wrap gap-2" aria-label="What we offer">
        {
          ['Nursing & clinical care', 'Personal care', 'Cleaning & home help', 'Meals', 'Social support & company'].map((s) => (
            <li>
              <a
                href="#services"
                class="inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-[0.82rem] font-bold text-white transition-colors hover:bg-white/30"
                style="background: rgba(255,255,255,0.13); border: 1px solid rgba(255,255,255,0.32); backdrop-filter: blur(8px);"
              >
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="#F2B33D" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>
                {s}
              </a>
            </li>
          ))
        }
      </ul>
      <ul class="hero-rise-3 mt-6 flex flex-wrap gap-x-6 gap-y-1.5 text-xs font-semibold text-white/70" aria-label="Accreditations">
        <li>My Aged Care · Approved Provider</li>
        <li>NDIS · Registered Provider</li>
        <li>Aged Care Quality Standards · Compliant</li>
      </ul>
    </div>
  </section>

  <!-- ============ STATEMENT ============ -->
  <section class="py-16 md:py-20" style="background: var(--bg);">
    <div class="sect-rv mx-auto w-[min(900px,100%-2.5rem)] text-center">
      <p class="rv text-xl font-extrabold leading-snug tracking-tight md:text-3xl" style="font-family: var(--font-head);">
        Getting older shouldn’t mean leaving home.
        <span style="color: var(--euca);">We make sure it doesn’t.</span>
      </p>
      <p class="rv rv-d1 mx-auto mt-5 max-w-2xl text-lg" style="color: var(--tx-soft);">
        We’re a small Melbourne team that does aged care the way it should be done —
        the same friendly faces, honest fees, and help that fits around your life.
      </p>
    </div>
  </section>


  <!-- ============ STATS ============ -->
  <section class="pb-4 pt-0" style="background: var(--bg);">
    <div class="sect-rv mx-auto grid w-[min(1280px,100%-2.5rem)] grid-cols-2 gap-4 md:grid-cols-4">
      {
        [
          ['24/7', 'care available, day and night', '24', '/7'],
          ['100%', 'fee transparency — calculator on this page', '100', '%'],
          ['$0', 'lock-in contracts or exit fees', '0', '', '$'],
          ['1 day', 'to hear back after you reach out', '1', ' day'],
        ].map(([_, label, num, suffix, prefix], i) => (
          <div class={`rv ${['', 'rv-d1', 'rv-d2', 'rv-d3'][i]} rounded-2xl border p-5 text-center`} style="border-color: var(--line);">
            <p class="text-3xl font-extrabold md:text-4xl" style="font-family: var(--font-head); color: var(--euca);">
              {prefix}<span data-countup={num}>0</span>{suffix}
            </p>
            <p class="mt-1 text-[0.85rem]" style="color: var(--tx-soft);">{label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============ VIDEO DIVIDER — everyday help ============ -->
  <div class="vdiv">
    <video src="/media/div-1.mp4" poster="/media/div-1.jpg" muted loop playsinline autoplay preload="metadata" data-ambient aria-hidden="true"></video>
    <div class="vdiv-scrim" aria-hidden="true"></div>
    <div class="vdiv-copy">
      <div class="mx-auto w-[min(1280px,100%-2.5rem)]">
        <p class="rv text-xl font-extrabold text-white md:text-3xl" style="font-family: var(--font-head); text-shadow: 0 2px 18px rgba(11,26,32,0.55);">
          Confidence with your health, every day.
        </p>
        <p class="rv rv-d1 mt-1 max-w-xl text-[0.95rem] text-white/85">Regular checks, medication sorted, someone keeping a caring eye on things.</p>
      </div>
    </div>
  </div>

  <!-- ============ SERVICES (ambient video cards) ============ -->
  <section id="services" class="py-14 md:py-20" style="background: var(--bg-sand);">
    <div class="sect-rv mx-auto w-[min(1280px,100%-2.5rem)]">
      <div class="mb-12 flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="rv mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">What we do</p>
          <h2 class="rv rv-d1 text-2xl md:text-4xl">Our services, your way</h2>
        </div>
        <p class="rv rv-d2 max-w-md text-[0.95rem]" style="color: var(--tx-soft);">
          Pick as much or as little help as you like. We fit around your routine — never the other way round.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {
          services.map((s, i) => (
            <a href="#contact" class={`vcard rv ${i % 2 ? 'rv-right rv-d2' : 'rv-left rv-d1'} group block overflow-hidden rounded-3xl transition-shadow hover:shadow-xl`} style="background: var(--bg-card); box-shadow: var(--shadow);" aria-label={`${s.title} — enquire now`}>
              <div class="vcard-media aspect-[16/9]" data-zoom>
                <video
                  src={s.video}
                  poster={s.poster}
                  muted loop playsinline autoplay preload="metadata"
                  data-ambient
                  aria-label={s.alt}
                ></video>
              </div>
              <div class="p-7">
                <h3 class="text-lg font-extrabold md:text-xl">{s.title}</h3>
                <p class="mt-2.5 text-[0.95rem]" style="color: var(--tx-soft);">{s.text}</p>
                <span class="mt-4 inline-flex items-center gap-1.5 text-[0.95rem] font-bold" style="color: var(--euca);">
                  Ask about this
                  <svg class="h-4.5 w-4.5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section id="how" class="py-14 md:py-20" style="background: var(--bg);">
    <div class="sect-rv mx-auto w-[min(1280px,100%-2.5rem)]">
      <p class="rv mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">Getting started</p>
      <h2 class="rv rv-d1 mb-12 text-2xl md:text-4xl">Three easy steps</h2>
      <div class="grid gap-6 md:grid-cols-3">
        {
          steps.map(([title, text, num], i) => (
            <div class={`rv rv-zoom ${['', 'rv-d1', 'rv-d2'][i]} overflow-hidden rounded-3xl border`} style="border-color: var(--line); background: var(--bg-card);">
              <div class="vcard-media aspect-[16/8]" data-zoom>
                <video src={`/media/step-${i + 1}.mp4`} poster={`/media/step-${i + 1}.jpg`} muted loop playsinline autoplay preload="metadata" data-ambient aria-hidden="true"></video>
              </div>
              <div class="p-6">
                <span class="text-3xl font-extrabold" style="color: var(--euca); opacity: 0.35; font-family: var(--font-head);">{num}</span>
                <h3 class="mt-2 text-lg font-extrabold">{title}</h3>
                <p class="mt-2 text-[0.95rem]" style="color: var(--tx-soft);">{text}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ FUNDING ============ -->
  <section id="funding" class="py-14 md:py-20" style="background: var(--blue-soft);">
    <div class="sect-rv mx-auto w-[min(1280px,100%-2.5rem)]">
      <div class="mb-12 max-w-2xl">
        <p class="rv mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--blue);">Funding</p>
        <h2 class="rv rv-d1 text-2xl md:text-4xl">The government pays for most of it</h2>
        <p class="rv rv-d2 mt-3 text-base" style="color: var(--tx-soft);">
          Australia has generous support for care at home. We’ll help you find the right door —
          and do the My Aged Care paperwork with you.
        </p>
      </div>
      <div id="fundGrid" class="fund-cycle grid gap-6 md:grid-cols-3">
        {
          funding.map((f, i) => (
            <a href="#contact" class={`fund-card rv ${['', 'rv-d1', 'rv-d2'][i]} group block rounded-3xl p-7 transition-all hover:-translate-y-1 hover:shadow-xl`} style="background: var(--bg-card); box-shadow: var(--shadow);" aria-label={`${f.name} — talk to us about this funding option`}>
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide" style="background: var(--blue-soft); color: var(--blue);">{f.tag}</span>
              <h3 class="mt-3 text-lg font-extrabold">{f.name}</h3>
              <p class="mt-2 text-[0.95rem]" style="color: var(--tx-soft);">{f.text}</p>
              <p class="mt-2 rounded-xl px-3 py-2 text-[0.85rem]" style="background: var(--blue-soft); color: var(--tx);">{f.eg}</p>
              <span class="mt-3 inline-flex items-center gap-1.5 text-[0.9rem] font-bold" style="color: var(--blue);">Talk to us
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </a>
          ))
        }
      </div>
      <p class="rv mt-8 text-[0.95rem]" style="color: var(--tx-soft);">
        Not sure which applies to you? <button id="askFundingChat" class="font-bold underline underline-offset-4" style="color: var(--blue);">Ask our chat helper</button> — it answers with real, current figures.
      </p>
    </div>
  </section>

  <!-- ============ VIDEO DIVIDER — recovery & mobility ============ -->
  <div class="vdiv">
    <video src="/media/div-2.mp4" poster="/media/div-2.jpg" muted loop playsinline autoplay preload="metadata" data-ambient aria-hidden="true"></video>
    <div class="vdiv-scrim" aria-hidden="true"></div>
    <div class="vdiv-copy">
      <div class="mx-auto w-[min(1280px,100%-2.5rem)]">
        <p class="rv text-xl font-extrabold text-white md:text-3xl" style="font-family: var(--font-head); text-shadow: 0 2px 18px rgba(11,26,32,0.55);">
          Back on your feet, at your pace.
        </p>
        <p class="rv rv-d1 mt-1 max-w-xl text-[0.95rem] text-white/85">Nursing and allied-health support that gets you moving again — safely, at home.</p>
      </div>
    </div>
  </div>

  <!-- ============ FEES ============ -->
  <section id="pricing" class="py-14 md:py-20" style="background: var(--bg);">
    <div class="sect-rv mx-auto w-[min(1280px,100%-2.5rem)]">
      <p class="rv mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">Fees</p>
      <h2 class="rv rv-d1 mb-4 text-2xl md:text-4xl">Honest fees, no surprises</h2>
      <p class="rv rv-d2 mb-8 max-w-2xl text-base" style="color: var(--tx-soft);">
        A <strong>15% care management</strong> and <strong>10% package management</strong> fee — both under the
        government caps — plus published hourly rates. See exactly where every dollar goes:
      </p>
      <div class="rv rv-d2"><PricingCalculator /></div>
    </div>
  </section>

  <!-- ============ WHY ASTRO CARE ============ -->
  <section class="py-14 md:py-20" style="background: var(--bg-sand);">
    <div class="sect-rv mx-auto w-[min(1280px,100%-2.5rem)]">
      <p class="rv mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">Why us</p>
      <h2 class="rv rv-d1 mb-12 text-2xl md:text-4xl">Small team. Big difference.</h2>
      <div class="grid gap-6 md:grid-cols-3">
        {
          [
            ['The same friendly faces', 'You’ll know your support workers by name — and they’ll know exactly how you take your tea.'],
            ['Answers any time of day', 'Our chat helper answers anything about aged care instantly, with real figures and sources — 24/7.'],
            ['Nothing hidden, ever', 'Fees published on this page. A calculator that shows every dollar. No lock-in contracts.'],
          ].map(([title, text], i) => (
            <div class={`rv ${['', 'rv-d1', 'rv-d2'][i]} rounded-3xl p-7`} style="background: var(--bg-card); box-shadow: var(--shadow);">
              <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="var(--euca)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21.35C6.4 17 3 13.5 3 9.9 3 7 5.2 5 8 5c1.6 0 3.1.8 4 2 0.9-1.2 2.4-2 4-2 2.8 0 5 2 5 4.9 0 3.6-3.4 7.1-9 11.45z"/></svg>
              <h3 class="mt-3 text-base font-extrabold">{title}</h3>
              <p class="mt-2 text-[0.95rem]" style="color: var(--tx-soft);">{text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>


  <!-- ============ VIDEO DIVIDER — plain-English guidance ============ -->
  <div class="vdiv">
    <video src="/media/div-3.mp4" poster="/media/div-3.jpg" muted loop playsinline autoplay preload="metadata" data-ambient aria-hidden="true"></video>
    <div class="vdiv-scrim" aria-hidden="true"></div>
    <div class="vdiv-copy">
      <div class="mx-auto w-[min(1280px,100%-2.5rem)]">
        <p class="rv text-xl font-extrabold text-white md:text-3xl" style="font-family: var(--font-head); text-shadow: 0 2px 18px rgba(11,26,32,0.55);">
          Everything explained, nothing assumed.
        </p>
        <p class="rv rv-d1 mt-1 max-w-xl text-[0.95rem] text-white/85">We sit down and walk through every option in plain English — as many times as it takes.</p>
      </div>
    </div>
  </div>

  <!-- ============ OUR STORY ============ -->
  <section id="about" class="py-14 md:py-20" style="background: var(--bg);">
    <div class="sect-rv mx-auto grid w-[min(1280px,100%-2.5rem)] items-center gap-10 lg:grid-cols-[1.1fr_1fr]">
      <div>
        <p class="rv mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">Our story</p>
        <h2 class="rv rv-d1 text-2xl md:text-4xl">Why we started Astro Care</h2>
        <div class="rv rv-d2 mt-5 grid gap-4 text-[1.02rem] leading-relaxed" style="color: var(--tx-soft);">
          <p>
            Astro Care began the way most good care does — with family. We watched people we love
            try to navigate the aged-care maze: the acronyms, the waiting lists, the fees nobody
            would explain in a straight sentence. We thought Melbourne deserved better.
          </p>
          <p>
            So we built the company we wished we'd found. A small team where you know your carers
            by name and they know how you take your tea. Every fee published right here on this
            page. Questions answered instantly, day or night — and a real local person on the
            phone when you want one.
          </p>
          <p>
            We're deliberately small and proudly local. That means every client gets the attention
            a big provider can't give — and the person helping you has probably driven down your
            street.
          </p>
        </div>
        <div class="rv rv-d3 mt-6 flex flex-wrap gap-3">
          <a href="#contact" class="btn-primary">Meet us — no obligation</a>
          <a href="#pricing" class="btn-ghost !border-2" style="color: var(--euca); border-color: var(--euca); background: transparent; backdrop-filter: none;">See our fees</a>
        </div>
      </div>
      <div class="rv rv-right overflow-hidden rounded-3xl" style="box-shadow: var(--shadow);">
        <div class="vcard-media aspect-[4/3]" data-zoom>
          <video src="/media/loop-social.mp4" poster="/media/poster-social.jpg" muted loop playsinline autoplay preload="metadata" data-ambient aria-label="A support worker bringing flowers to a client at home"></video>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ RESOURCES (one-stop shop) ============ -->
  <section id="resources" class="py-14 md:py-20" style="background: var(--bg-sand);">
    <div class="sect-rv mx-auto w-[min(1280px,100%-2.5rem)]">
      <p class="rv mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">Helpful links</p>
      <h2 class="rv rv-d1 mb-4 text-2xl md:text-4xl">Everything in one place</h2>
      <p class="rv rv-d2 mb-10 max-w-2xl text-base" style="color: var(--tx-soft);">
        The official services you'll deal with on your aged-care journey — all one tap away.
        Not sure where to start? Ask our chat, or <a href="#contact" class="font-bold underline underline-offset-4" style="color: var(--euca);">leave your number</a> and we'll walk you through it.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            ['My Aged Care', 'Apply for an assessment and manage your care online', 'https://www.myagedcare.gov.au/', 'myagedcare.png'],
            ['Eligibility checker', 'A 15-minute online check — should you apply?', 'https://www.myagedcare.gov.au/am-i-eligible', ''],
            ['Support at Home', 'The government program that funds care at home', 'https://www.health.gov.au/our-work/support-at-home', 'health.png'],
            ['Services Australia', 'Aged-care costs, income assessments and payments', 'https://www.servicesaustralia.gov.au/aged-care', 'servicesaustralia.png'],
            ['Carer Gateway', 'Free support and respite for family carers', 'https://www.carergateway.gov.au/', 'carergateway.png'],
            ['Dementia Australia', 'Advice and support for dementia — 1800 100 500', 'https://www.dementia.org.au/', 'dementia.png'],
            ['Quality & Safety Commission', 'Your rights, provider standards and complaints', 'https://www.agedcarequality.gov.au/', 'acqsc.png'],
            ['OPAN advocacy', 'Free, independent aged-care advocates — 1800 700 600', 'https://opan.org.au/', 'opan.png'],
          ].map(([name, desc, url, logo], i) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class={`rv ${['', 'rv-d1', 'rv-d2', 'rv-d3'][i % 4]} group flex flex-col rounded-2xl border p-5 transition-all hover:-translate-y-1 hover:shadow-lg`}
              style="border-color: var(--line); background: var(--bg-card);"
            >
              <span class="flex items-center gap-2.5 text-[0.98rem] font-extrabold" style="font-family: var(--font-head);">
                {logo ? (
                  <img src={`/media/logos/${logo}`} alt="" width="24" height="24" class="h-6 w-6 shrink-0 rounded" loading="lazy" />
                ) : (
                  <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="var(--euca)" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm-1.2 14.4-4-4 1.7-1.7 2.3 2.3 5-5 1.7 1.7-6.7 6.7z"/></svg>
                )}
                <span class="flex-1">{name}</span>
                <svg class="h-4 w-4 shrink-0 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="var(--euca)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
              </span>
              <span class="mt-1.5 text-[0.85rem]" style="color: var(--tx-soft);">{desc}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section id="faq" class="py-14 md:py-20" style="background: var(--bg);">
    <div class="sect-rv mx-auto w-[min(900px,100%-2.5rem)]">
      <p class="rv mb-2 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">Questions</p>
      <h2 class="rv rv-d1 mb-8 text-2xl md:text-4xl">The things families ask us first</h2>
      <div class="rv rv-d2 grid gap-3">
        {
          [
            ['Where does Astro Care operate?', 'Across all of Melbourne — from the inner suburbs to the outer ring. If you’re unsure whether we reach you, ask the chat or leave your number and we’ll confirm straight away.'],
            ['Who is eligible for government-funded care at home?', 'Generally Australians aged 65+ (50+ for Aboriginal and Torres Strait Islander people) who need some help to keep living at home. Eligibility is confirmed through a free My Aged Care assessment — we help you arrange it and sit with you through the process.'],
            ['How much will home care cost us?', 'For most people the government pays the large majority. Depending on your assessed level, funding ranges from about $11,000 to $78,000 a year. Our management fees are 15% + 10%, under the government caps, and every rate is published on this page — use the calculator above to see exactly where each dollar goes.'],
            ['What’s the difference between Support at Home and CHSP?', 'CHSP is entry-level help (a clean, meals, transport) with a small contribution per service and no big paperwork. Support at Home is the main program for ongoing care — funding is set by an assessment and covers nursing, personal care and everyday help. We’ll tell you honestly which fits your situation.'],
            ['How quickly can care start?', 'Privately funded care can start within days. Government-funded care depends on your assessment and the national queue — often weeks to a few months. Many families start small privately and switch when funding is approved, so nobody waits without help.'],
            ['Do you provide nursing as well as everyday help?', 'Yes — registered nurses for wound care, medication and health checks, alongside personal care, cleaning, meals and social support. One team, one plan, at home.'],
            ['Can we change or cancel services later?', 'Any time. There are no lock-in contracts and no exit fees — care flexes up, down or off as your needs change.'],
            ['We’re just starting and it’s confusing. What’s the first step?', 'Say hello. Use the chat for instant answers, or leave your number and we’ll ring you back within one business day, talk through your situation, and handle the My Aged Care paperwork with you — no obligation.'],
          ].map(([q, a]) => (
            <details class="group rounded-2xl border px-5 py-1" style="border-color: var(--line); background: var(--bg-card);">
              <summary class="flex min-h-12 cursor-pointer list-none items-center justify-between gap-3 py-2.5 text-[1rem] font-extrabold" style="font-family: var(--font-head);">
                {q}
                <svg class="h-5 w-5 shrink-0 transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="var(--euca)" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
              </summary>
              <p class="pb-4 text-[0.95rem]" style="color: var(--tx-soft);">{a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ VIDEO LIBRARY (official explainers) ============ -->
  <section id="videos" class="pb-14 pt-2 md:pb-20" style="background: var(--bg-sand);">
    <div class="sect-rv mx-auto w-[min(1280px,100%-2.5rem)]">
      <h2 class="rv mb-3 text-xl md:text-2xl">Prefer to watch? Straight from the government</h2>
      <p class="rv rv-d1 mb-8 max-w-2xl text-[0.95rem]" style="color: var(--tx-soft);">
        Short official videos that explain how aged care works — from the Department of Health and the
        Quality &amp; Safety Commission.
      </p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            ['GV8O_GBUhI0', 'My Aged Care — the aged care assessment', 'Australian Dept of Health'],
            ['xb3E3mgDCe8', 'Preparing for your assessment', 'Australian Dept of Health'],
            ['2OQETSwsRzs', 'Support at Home — how contributions work', 'Australian Dept of Health'],
            ['3vne8GVKvFA', 'A new era of aged care', 'Quality & Safety Commission'],
          ].map(([id, title, channel], i) => (
            <figure class={`rv ${['', 'rv-d1', 'rv-d2', 'rv-d3'][i]} overflow-hidden rounded-2xl border`} style="border-color: var(--line); background: var(--bg-card); box-shadow: var(--shadow);">
              <div class="aspect-video">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${id}`}
