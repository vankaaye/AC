---
/**
 * PricingCalculator.astro
 * ------------------------------------------------------------------
 * "Pricing & Fee Transparency Calculator" — a single compact card
 * (the surrounding #pricing section, heading and intro live in
 * index.astro).
 *
 * Shows, in plain English:
 *   1. The weekly government subsidy for each HCP level (1–4),
 *      with a real-life example of what that level typically covers.
 *   2. Astro Care's Care Management fee (15% of the package).
 *   3. Astro Care's Package Management fee (10% of the package).
 *   4. What's left for actual care, and roughly how many hours of
 *      their chosen service that buys each week.
 *
 * Rates are indicative and should be kept in step with the published
 * Astro Care price list and My Aged Care subsidy rates.
 * ------------------------------------------------------------------
 */

const LEVELS = [
  { level: 1, label: 'Level 1 — basic', weekly: 205, eg: 'e.g. a weekly clean plus help with the shopping' },
  { level: 2, label: 'Level 2 — low', weekly: 361, eg: 'e.g. two visits a week — cleaning, meals or a shower assist' },
  { level: 3, label: 'Level 3 — intermediate', weekly: 786, eg: 'e.g. help most days: personal care, meals, nurse check-ins' },
  { level: 4, label: 'Level 4 — high', weekly: 1192, eg: 'e.g. daily visits — personal care, nursing, meals and respite' },
];

const SERVICES = [
  { key: 'personal', label: 'Personal care (showering, dressing)', rate: 72 },
  { key: 'nursing', label: 'Nursing (wounds, medication)', rate: 115 },
  { key: 'domestic', label: 'Domestic assistance (cleaning, laundry)', rate: 65 },
  { key: 'social', label: 'Social support & outings', rate: 65 },
  { key: 'meals', label: 'Meal preparation', rate: 65 },
];

const CARE_MGMT_PCT = 15;    // % of package — capped at 20% by the Commission
const PKG_MGMT_PCT = 10;     // % of package — capped at 15% by the Commission
---

<div
  class="grid gap-6 rounded-3xl border hc-border p-4 sm:p-6 lg:grid-cols-2"
  style="background: var(--bg-card); border-color: var(--line); box-shadow: var(--shadow);"
>
  <!-- ============ HOW IT WORKS (spans both columns) ============ -->
  <div class="lg:col-span-2">
    <p class="rounded-2xl px-4 py-3 text-[0.95rem]" style="background: var(--euca-soft); color: var(--tx);">
      <strong>How this works:</strong> answer the 3 quick questions below and the panel
      instantly shows what the government pays you, what Astro Care charges, and roughly how many
      <strong>hours of care</strong> that buys each week. Nothing is sent anywhere — it's just a guide.
    </p>
  </div>

  <!-- ============ INPUTS ============ -->
  <div>
    <p class="mb-4 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">Your details</p>
    <fieldset class="mb-6">
      <legend class="readable mb-3 text-lg font-black" style="font-family: var(--font-head);">
        1. Your Home Care Package level
      </legend>
      <div class="grid gap-2.5">
        {
          LEVELS.map((l, i) => (
            <label
              class="block cursor-pointer rounded-2xl border-2 px-3 py-2.5 transition-colors has-checked:border-[var(--euca)] has-checked:bg-[var(--euca-soft)]"
              style="border-color: var(--line);"
            >
              <span class="flex min-h-8 items-center gap-2.5 text-[0.95rem] font-bold">
                <input
                  type="radio"
                  name="hcpLevel"
                  value={l.weekly}
                  checked={i === 1}
                  class="h-5.5 w-5.5 accent-[var(--euca)]"
                />
                <span class="flex-1">{l.label}</span>
                <span class="whitespace-nowrap font-black" style="color: var(--euca);">${l.weekly}/wk</span>
              </span>
              <span class="mt-0.5 block pl-8 text-[0.82rem]" style="color: var(--tx-soft);">{l.eg}</span>
            </label>
          ))
        }
      </div>
      <p class="mt-2 text-[0.9rem]" style="color: var(--tx-soft);">
        Not sure of your level? Your My Aged Care letter says — or ask us and we'll check together.
      </p>
    </fieldset>

    <fieldset class="mb-6">
      <legend class="readable mb-3 text-lg font-black" style="font-family: var(--font-head);">
        2. The service you use most
      </legend>
      <select
        id="calcService"
        class="min-h-11 w-full rounded-xl border-2 px-3 text-[0.95rem] font-bold"
        style="border-color: var(--line); background: var(--bg);"
        aria-label="Choose the service you use most"
      >
        {SERVICES.map((s) => <option value={s.rate}>{s.label} — ${s.rate}/hour</option>)}
      </select>
    </fieldset>

    <fieldset>
      <legend class="readable mb-3 text-lg font-black" style="font-family: var(--font-head);">
        3. Hours of help each week
      </legend>
      <div class="flex items-center gap-3">
        <button id="calcLess" class="btn-primary hc-border !min-h-11 !w-11 !p-0 !text-xl" aria-label="One hour less">−</button>
        <output id="calcHours" class="min-w-10 text-center text-2xl font-black" style="font-family: var(--font-head);" aria-live="polite">6</output>
        <button id="calcMore" class="btn-primary hc-border !min-h-11 !w-11 !p-0 !text-xl" aria-label="One hour more">+</button>
        <span class="text-[0.95rem] font-bold" style="color: var(--tx-soft);">hours / week</span>
      </div>
    </fieldset>
  </div>

  <!-- ============ RESULTS ============ -->
  <div class="rounded-2xl p-5 md:p-6" style="background: var(--euca-soft);" aria-live="polite">
    <p class="mb-1 text-sm font-bold uppercase tracking-widest" style="color: var(--euca);">Your weekly estimate</p>
    <h3 class="readable mb-4 text-lg" style="color: var(--tx-soft);">Where every dollar goes</h3>
    <dl class="grid gap-2.5 text-[0.95rem]">
      <div class="flex items-center justify-between gap-4 border-b pb-2.5" style="border-color: var(--line);">
        <dt>💰 The government gives you</dt>
        <dd class="whitespace-nowrap text-xl font-black" style="color: var(--euca);" id="outSubsidy">$361</dd>
      </div>
      <div class="flex items-center justify-between gap-4 border-b pb-2.5" style="border-color: var(--line);">
        <dt>➖ Care management <span style="color: var(--tx-soft);">({CARE_MGMT_PCT}%)</span><br /><small class="text-[0.82rem]" style="color: var(--tx-soft);">Your nurse-led care plan, reviews &amp; coordination</small></dt>
        <dd class="whitespace-nowrap text-xl font-black" id="outCareMgmt">−$54</dd>
      </div>
      <div class="flex items-center justify-between gap-4 border-b pb-2.5" style="border-color: var(--line);">
        <dt>➖ Package management <span style="color: var(--tx-soft);">({PKG_MGMT_PCT}%)</span><br /><small class="text-[0.82rem]" style="color: var(--tx-soft);">Statements, invoicing &amp; compliance</small></dt>
        <dd class="whitespace-nowrap text-xl font-black" id="outPkgMgmt">−$36</dd>
      </div>
      <div class="flex items-center justify-between gap-4 rounded-xl px-3 py-2" style="background: var(--bg-card);">
        <dt class="font-black">✅ Left for your actual care</dt>
        <dd class="whitespace-nowrap text-2xl font-black" style="color: var(--euca);" id="outCare">$271</dd>
      </div>
      <div class="flex items-center justify-between gap-4 pt-1">
        <dt class="font-bold">⏱️ Which buys about</dt>
        <dd class="whitespace-nowrap text-xl font-black" id="outHours">3.8 hrs/wk</dd>
      </div>
    </dl>
    <p class="mt-3 rounded-xl p-3 text-[0.9rem]" style="background: var(--sun-soft); color: var(--tx);" id="outNote">
      You asked about <strong id="outAskHours">6</strong> hours — a higher package level or a small
      personal contribution can bridge the gap. Ask us and we'll find the kindest way.
    </p>
    <p class="mt-3 text-[0.82rem]" style="color: var(--tx-soft);">
      A friendly estimate only, based on Astro Care's published rates and current subsidy levels.
      Exact figures are always confirmed in writing before any care starts — as required by the
      Aged Care Quality and Safety Commission.
    </p>
    <a href="tel:+611800278762" class="btn-call hc-border mt-4 w-full">Talk fees with a real person</a>
  </div>
</div>

<script is:inline>
  (function () {
    var CARE_PCT = 0.15;
    var PKG_PCT = 0.10;
    var hours = 6;

    var $ = function (id) { return document.getElementById(id); };
    function dollars(n) { return '$' + Math.round(n).toLocaleString('en-AU'); }

    function currentSubsidy() {
      var checked = document.querySelector('input[name="hcpLevel"]:checked');
      return checked ? Number(checked.value) : 361;
    }

    function recalc() {
      var subsidy = currentSubsidy();
      var rate = Number($('calcService').value);
      var careMgmt = subsidy * CARE_PCT;
      var pkgMgmt = subsidy * PKG_PCT;
      var forCare = subsidy - careMgmt - pkgMgmt;
      var coveredHours = forCare / rate;

      $('outSubsidy').textContent = dollars(subsidy);
      $('outCareMgmt').textContent = '−' + dollars(careMgmt);
      $('outPkgMgmt').textContent = '−' + dollars(pkgMgmt);
      $('outCare').textContent = dollars(forCare);
      $('outHours').textContent = coveredHours.toFixed(1) + ' hrs/wk';
      $('calcHours').textContent = String(hours);
      $('outAskHours').textContent = String(hours);
      $('outNote').style.display = hours > coveredHours ? '' : 'none';
    }

    document.querySelectorAll('input[name="hcpLevel"]').forEach(function (r) {
      r.addEventListener('change', recalc);
    });
    $('calcService').addEventListener('change', recalc);
    $('calcMore').addEventListener('click', function () { if (hours < 40) { hours++; recalc(); } });
    $('calcLess').addEventListener('click', function () { if (hours > 1) { hours--; recalc(); } });

    recalc();
  })();
</script>
