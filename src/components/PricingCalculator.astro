---
/**
 * PricingCalculator.astro
 * ------------------------------------------------------------------
 * "Pricing & Fee Transparency Calculator"
 *
 * Lets a family estimate, in plain English:
 *   1. The weekly government subsidy for each HCP level (1–4).
 *   2. Astro Care's Care Management fee (15% of the package).
 *   3. Astro Care's Package Management fee (10% of the package).
 *   4. What's left for actual care, and roughly how many hours of
 *      their chosen service that buys each week.
 *
 * Design rules for seniors:
 *   - Radio buttons and +/− steppers only (56px+ targets), no sliders.
 *   - Results update instantly, in large type, with dollars first.
 *   - A clear "estimate only" disclaimer, as fee schedules change.
 *
 * Rates are indicative and should be kept in step with the published
 * Astro Care price list and My Aged Care subsidy rates.
 * ------------------------------------------------------------------
 */

const LEVELS = [
  { level: 1, label: 'Level 1 — basic care needs', weekly: 205 },
  { level: 2, label: 'Level 2 — low care needs', weekly: 361 },
  { level: 3, label: 'Level 3 — intermediate care needs', weekly: 786 },
  { level: 4, label: 'Level 4 — high care needs', weekly: 1192 },
];

const SERVICES = [
  { key: 'personal', label: 'Personal care (showering, dressing)', rate: 72 },
  { key: 'nursing', label: 'Nursing (wounds, medication)', rate: 115 },
  { key: 'domestic', label: 'Domestic assistance (cleaning, laundry)', rate: 65 },
  { key: 'social', label: 'Social support & outings', rate: 65 },
  { key: 'meals', label: 'Meal preparation', rate: 65 },
];

const CARE_MGMT_PCT = 15;    // % of package — capped at 20% by the Commission
const PKG_MGMT_PCT = 10;     // % of package — capped at 15% by the Commission
---

<section id="pricing" class="py-16" style="background: var(--bg-sand);" aria-labelledby="pricingHeading">
  <div class="mx-auto w-[min(1220px,100%-2.5rem)]">
    <div class="max-w-3xl">
      <h2 id="pricingHeading" class="readable text-4xl md:text-5xl mb-4">
        Clear fees, <em class="not-italic" style="color: var(--euca);">no surprises</em>
      </h2>
      <p class="readable text-xl mb-3" style="color: var(--tx-soft);">
        Every Home Care Package provider charges management fees — the difference is how honestly
        they're shown. Here are ours, out in the open. Choose your package level below and see
        exactly where every dollar goes.
      </p>
    </div>

    <div
      class="mt-8 grid gap-6 rounded-3xl border-4 hc-border p-6 md:p-9 lg:grid-cols-2"
      style="background: var(--bg-card); border-color: var(--line); box-shadow: var(--shadow);"
    >
      <!-- ============ INPUTS ============ -->
      <div>
        <fieldset class="mb-7">
          <legend class="readable text-2xl font-black mb-3" style="font-family: var(--font-head);">
            1. Your Home Care Package level
          </legend>
          <div class="grid gap-3">
            {
              LEVELS.map((l, i) => (
                <label
                  class="flex min-h-14 cursor-pointer items-center gap-4 rounded-2xl border-4 px-4 py-3 text-xl font-bold transition-colors has-checked:border-[var(--euca)] has-checked:bg-[var(--euca-soft)]"
                  style="border-color: var(--line);"
                >
                  <input
                    type="radio"
                    name="hcpLevel"
                    value={l.weekly}
                    checked={i === 1}
                    class="h-7 w-7 accent-[var(--euca)]"
                  />
                  <span class="flex-1">{l.label}</span>
                  <span class="whitespace-nowrap font-black" style="color: var(--euca);">${l.weekly}/wk</span>
                </label>
              ))
            }
          </div>
          <p class="mt-2 text-lg" style="color: var(--tx-soft);">
            Not sure of your level? Your My Aged Care letter says — or call us and we'll check together.
          </p>
        </fieldset>

        <fieldset class="mb-7">
          <legend class="readable text-2xl font-black mb-3" style="font-family: var(--font-head);">
            2. The service you use most
          </legend>
          <select
            id="calcService"
            class="min-h-14 w-full rounded-2xl border-4 px-4 text-xl font-bold"
            style="border-color: var(--line); background: var(--bg);"
            aria-label="Choose the service you use most"
          >
            {SERVICES.map((s) => <option value={s.rate}>{s.label} — ${s.rate}/hour</option>)}
          </select>
        </fieldset>

        <fieldset>
          <legend class="readable text-2xl font-black mb-3" style="font-family: var(--font-head);">
            3. Hours of help each week
          </legend>
          <div class="flex items-center gap-4">
            <button id="calcLess" class="btn-primary hc-border !min-h-16 !w-16 !p-0 !text-3xl" aria-label="One hour less">−</button>
            <output id="calcHours" class="min-w-24 text-center text-4xl font-black" style="font-family: var(--font-head);" aria-live="polite">6</output>
            <button id="calcMore" class="btn-primary hc-border !min-h-16 !w-16 !p-0 !text-3xl" aria-label="One hour more">+</button>
            <span class="text-xl font-bold" style="color: var(--tx-soft);">hours / week</span>
          </div>
        </fieldset>
      </div>

      <!-- ============ RESULTS ============ -->
      <div class="rounded-2xl p-6 md:p-8" style="background: var(--euca-soft);" aria-live="polite">
        <h3 class="readable text-2xl mb-5">Your weekly estimate</h3>
        <dl class="grid gap-4 text-xl">
          <div class="flex items-center justify-between gap-4 border-b-2 pb-3" style="border-color: var(--line);">
            <dt>Government subsidy for your package</dt>
            <dd class="whitespace-nowrap text-2xl font-black" style="color: var(--euca);" id="outSubsidy">$361</dd>
          </div>
          <div class="flex items-center justify-between gap-4 border-b-2 pb-3" style="border-color: var(--line);">
            <dt>Care Management fee ({CARE_MGMT_PCT}%)<br /><small class="text-base" style="color: var(--tx-soft);">Your nurse-led care plan, reviews &amp; coordination</small></dt>
            <dd class="whitespace-nowrap text-2xl font-black" id="outCareMgmt">−$54</dd>
          </div>
          <div class="flex items-center justify-between gap-4 border-b-2 pb-3" style="border-color: var(--line);">
            <dt>Package Management fee ({PKG_MGMT_PCT}%)<br /><small class="text-base" style="color: var(--tx-soft);">Statements, invoicing &amp; compliance</small></dt>
            <dd class="whitespace-nowrap text-2xl font-black" id="outPkgMgmt">−$36</dd>
          </div>
          <div class="flex items-center justify-between gap-4 border-b-2 pb-3" style="border-color: var(--line);">
            <dt class="font-black">Left for your care each week</dt>
            <dd class="whitespace-nowrap text-3xl font-black" style="color: var(--euca);" id="outCare">$271</dd>
          </div>
          <div class="flex items-center justify-between gap-4">
            <dt>Covers about</dt>
            <dd class="whitespace-nowrap text-2xl font-black" id="outHours">3.8 hrs/wk</dd>
          </div>
        </dl>
        <p class="mt-4 rounded-xl p-4 text-lg" style="background: var(--sun-soft); color: var(--tx);" id="outNote">
          You asked about <strong id="outAskHours">6</strong> hours — a higher package level or a small
          personal contribution can bridge the gap. Call us and we'll find the kindest way.
        </p>
        <p class="mt-4 text-base" style="color: var(--tx-soft);">
          This is a friendly estimate only, based on Astro Care's published rates and current subsidy
          levels. Exact figures are always confirmed in writing before any care starts — as required
          by the Aged Care Quality and Safety Commission.
        </p>
        <a href="tel:+611800278762" class="btn-call hc-border mt-5 w-full">Talk fees with a real person</a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var CARE_PCT = 0.15;
    var PKG_PCT = 0.10;
    var hours = 6;

    var $ = function (id) { return document.getElementById(id); };
    function dollars(n) { return '$' + Math.round(n).toLocaleString('en-AU'); }

    function currentSubsidy() {
      var checked = document.querySelector('input[name="hcpLevel"]:checked');
      return checked ? Number(checked.value) : 361;
    }

    function recalc() {
      var subsidy = currentSubsidy();
      var rate = Number($('calcService').value);
      var careMgmt = subsidy * CARE_PCT;
      var pkgMgmt = subsidy * PKG_PCT;
      var forCare = subsidy - careMgmt - pkgMgmt;
      var coveredHours = forCare / rate;

      $('outSubsidy').textContent = dollars(subsidy);
      $('outCareMgmt').textContent = '−' + dollars(careMgmt);
      $('outPkgMgmt').textContent = '−' + dollars(pkgMgmt);
      $('outCare').textContent = dollars(forCare);
      $('outHours').textContent = coveredHours.toFixed(1) + ' hrs/wk';
      $('calcHours').textContent = String(hours);
      $('outAskHours').textContent = String(hours);
      $('outNote').style.display = hours > coveredHours ? '' : 'none';
    }

    document.querySelectorAll('input[name="hcpLevel"]').forEach(function (r) {
      r.addEventListener('change', recalc);
    });
    $('calcService').addEventListener('change', recalc);
    $('calcMore').addEventListener('click', function () { if (hours < 40) { hours++; recalc(); } });
    $('calcLess').addEventListener('click', function () { if (hours > 1) { hours--; recalc(); } });

    recalc();
  })();
</script>
