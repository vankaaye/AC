---
/**
 * ChatWidget.astro
 * ------------------------------------------------------------------
 * "Chat with us" — an instant-answer AI-style chat helper.
 *
 * Opens from the button in the persistent Sarah bar. Answers common
 * aged-care questions instantly (funding, fees, services, hours,
 * getting started) from a built-in knowledge base, and always offers
 * the human escape hatches: call 1800 ASTRO or request a callback.
 *
 * Senior-friendly rules: opens on click only, 20px+ text, huge
 * targets, quick-reply chips so nobody has to type, Escape closes,
 * and it plainly introduces itself as an automated helper.
 * No data leaves the page.
 * ------------------------------------------------------------------
 */
---

<div
  id="chatPanel"
  class="fixed inset-x-2 bottom-20 z-[125] hidden max-h-[74vh] flex-col overflow-hidden rounded-3xl border-4 hc-border sm:inset-x-auto sm:right-3 sm:w-[26rem] md:bottom-24"
  style="background: var(--bg-card); border-color: var(--euca); box-shadow: var(--shadow);"
  role="dialog"
  aria-modal="false"
  aria-label="Chat with Astro Care"
>
  <!-- Header -->
  <div class="flex items-center gap-3 p-4" style="background: var(--euca); color: #fff;">
    <span class="relative inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full" style="background: var(--sun);">
      <svg class="h-9 w-9" viewBox="0 0 48 48" fill="none" aria-hidden="true"><circle cx="24" cy="24" r="22" fill="#FFC24B"></circle><path d="M13 38 L24 12 L35 38" fill="none" stroke="#24523E" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"></path><path d="M16.5 29.5 h3.3 l1.65 -3.9 l2.4 7.8 l2.1 -5.1 l1.2 1.2 h4.35" fill="none" stroke="#B23E1F" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
    </span>
    <div class="min-w-0 flex-1">
      <p class="text-xl font-black leading-tight" style="font-family: var(--font-head);">Astro — our chat helper</p>
      <p class="text-base opacity-90">Instant answers, any time of day</p>
    </div>
    <button id="chatClose" class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-3xl font-bold hover:bg-white/15" aria-label="Close chat">×</button>
  </div>

  <!-- Messages -->
  <div id="chatLog" class="flex-1 space-y-3 overflow-y-auto p-4" style="min-height: 16rem; max-height: 50vh;" aria-live="polite"></div>

  <!-- Quick-reply chips: nobody has to type -->
  <div id="chatChips" class="flex gap-2 overflow-x-auto px-4 pb-2" style="scrollbar-width: thin;" aria-label="Quick questions"></div>

  <!-- Input -->
  <form id="chatForm" class="flex gap-2 border-t-2 p-3" style="border-color: var(--line);">
    <label class="sr-only" for="chatInput">Type your question</label>
    <input
      id="chatInput"
      type="text"
      placeholder="Type a question…"
      autocomplete="off"
      class="min-h-13 w-full min-w-0 flex-1 rounded-2xl border-4 px-4 text-lg"
      style="border-color: var(--line); background: var(--bg); font-family: var(--font-body);"
    />
    <button type="submit" class="btn-primary hc-border !min-h-13 !px-5" aria-label="Send message">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4z"/><path d="M22 2 11 13"/></svg>
    </button>
  </form>
</div>

<script is:inline>
  (function () {
    var panel = document.getElementById('chatPanel');
    var log = document.getElementById('chatLog');
    var chips = document.getElementById('chatChips');
    var form = document.getElementById('chatForm');
    var input = document.getElementById('chatInput');
    var openBtn = document.getElementById('openChat');
    var greeted = false;

    /* ---------- knowledge base ---------- */
    var KB = [
      {
        keys: ['fund', 'package', 'hcp', 'chsp', 'government', 'subsid', 'my aged care', 'eligib', 'assess', 'acat', 'start', 'begin', 'how do i'],
        chip: 'How does funding work?',
        reply: "Good news — the government helps pay for most care at home. There are two doors in: a <strong>Home Care Package</strong> (for regular, ongoing help — Levels 1 to 4) and the <strong>Commonwealth Home Support Programme</strong> (for a little help, like cleaning or meals). Most Australians over 65 qualify for one of them.<br><br>You don't need to work out which — <a href='/#funding'>see the step-by-step guide</a>, or call <a href='tel:+611800278762'>1800 ASTRO</a> and we'll sort it together, including the My Aged Care paperwork.",
      },
      {
        keys: ['fee', 'cost', 'price', 'pay', 'charge', 'expensive', 'money', 'dollar', 'management'],
        chip: 'What are your fees?',
        reply: "We keep fees simple and public: a <strong>15% Care Management</strong> fee and a <strong>10% Package Management</strong> fee — both under the caps set by the Aged Care Quality and Safety Commission — plus published hourly rates for care.<br><br>Try the <a href='/#pricing'>fee calculator</a> to see exactly where every dollar of your package goes, in about 20 seconds.",
      },
      {
        keys: ['service', 'clean', 'meal', 'cook', 'nurse', 'nursing', 'shower', 'medic', 'garden', 'shopping', 'transport', 'company', 'social', 'help'],
        chip: 'What services do you offer?',
        reply: "Four main kinds of help, mixed and matched your way:<br>• <strong>Clinical care</strong> — nurses for wounds, medication and health checks<br>• <strong>Social support</strong> — visits, outings and good company<br>• <strong>Domestic assistance</strong> — cleaning, laundry and gardening<br>• <strong>Meal preparation</strong> — cooked fresh in your own kitchen<br><br><a href='/#services'>See the services</a>, or tell me what you need help with!",
      },
      {
        keys: ['hour', 'open', 'when', 'time', 'weekend', 'contact', 'email'],
        chip: 'When can I reach you?',
        reply: "Our friendly enquiry line <a href='tel:+611800278762'>1800 ASTRO (278 762)</a> is open <strong>Monday–Friday 8am–6pm</strong> and <strong>Saturday 9am–4pm</strong>. Care itself never stops — it runs 24/7, every day of the year. You can also email <a href='mailto:info@astrocare.com.au'>info@astrocare.com.au</a>.",
      },
      {
        keys: ['person', 'human', 'call', 'talk', 'speak', 'phone', 'callback', 'ring'],
        chip: 'Talk to a real person',
        reply: "Of course — we love a chat. Call <a href='tel:+611800278762'><strong>1800 ASTRO (278 762)</strong></a> and a real person answers, or <a href='/#contact'>ask us to call you back</a> and we'll ring within one business day.",
      },
      {
        keys: ['dementia', 'memory', 'alzheim', 'confus'],
        chip: 'Dementia support?',
        reply: "Yes — our carers complete specialist dementia training, and we design gentle routines that keep days calm and familiar. It's kind, patient care that works <em>with</em> your loved one's world. Call <a href='tel:+611800278762'>1800 ASTRO</a> and ask about memory support — it's a conversation best had person to person.",
      },
      {
        keys: ['ndis', 'disab'],
        chip: null,
        reply: "Yes, we're an <strong>NDIS registered provider</strong> — if you or a family member has an NDIS plan, we can deliver in-home supports under it. Call <a href='tel:+611800278762'>1800 ASTRO</a> with your plan handy and we'll walk through it.",
      },
    ];
    var FALLBACK = "I'm just a simple helper, and I want you to get a proper answer! The quickest way is to call <a href='tel:+611800278762'><strong>1800 ASTRO (278 762)</strong></a> — a real person answers. Or try one of the buttons below.";

    /* ---------- rendering ---------- */
    function bubble(html, who) {
      var div = document.createElement('div');
      div.className = who === 'you'
        ? 'ml-10 rounded-2xl rounded-br-md px-4 py-3 text-lg'
        : 'mr-6 rounded-2xl rounded-bl-md px-4 py-3 text-lg';
      div.style.cssText = who === 'you'
        ? 'background: var(--euca); color: #fff;'
        : 'background: var(--euca-soft); color: var(--tx);';
      div.innerHTML = html;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      return div;
    }

    function botReply(html) {
      var typing = bubble('<span aria-hidden="true">···</span><span class="sr-only">Astro is typing</span>', 'bot');
      setTimeout(function () {
        typing.innerHTML = html;
        log.scrollTop = log.scrollHeight;
      }, 550);
    }

    function answer(text) {
      var t = text.toLowerCase();
      var best = null, bestScore = 0;
      KB.forEach(function (item) {
        var score = 0;
        item.keys.forEach(function (k) { if (t.indexOf(k) !== -1) score++; });
        if (score > bestScore) { bestScore = score; best = item; }
      });
      botReply(best ? best.reply : FALLBACK);
    }

    function renderChips() {
      chips.innerHTML = '';
      KB.filter(function (i) { return i.chip; }).forEach(function (item) {
        var b = document.createElement('button');
        b.type = 'button';
        b.textContent = item.chip;
        b.className = 'shrink-0 whitespace-nowrap rounded-full border-2 px-4 py-2 text-base font-bold min-h-11';
        b.style.cssText = 'border-color: var(--euca); color: var(--euca); font-family: var(--font-head);';
        b.addEventListener('click', function () {
          bubble(item.chip, 'you');
          botReply(item.reply);
        });
        chips.appendChild(b);
      });
    }

    /* ---------- open / close ---------- */
    function openChat() {
      panel.classList.remove('hidden');
      panel.classList.add('flex');
      if (openBtn) openBtn.setAttribute('aria-expanded', 'true');
      if (!greeted) {
        greeted = true;
        renderChips();
        botReply("G'day! I'm <strong>Astro</strong>, the Astro Care chat helper — I give instant answers about funding, fees and our services, day or night. What can I help with? (For anything personal, <a href='tel:+611800278762'>1800 ASTRO</a> is always the warmest option.)");
      }
      input.focus();
    }
    function closeChat() {
      panel.classList.add('hidden');
      panel.classList.remove('flex');
      if (openBtn) { openBtn.setAttribute('aria-expanded', 'false'); openBtn.focus(); }
    }

    if (openBtn) openBtn.addEventListener('click', function () {
      panel.classList.contains('hidden') ? openChat() : closeChat();
    });
    document.getElementById('chatClose').addEventListener('click', closeChat);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !panel.classList.contains('hidden')) closeChat();
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var text = input.value.trim();
      if (!text) return;
      bubble(text.replace(/</g, '&lt;'), 'you');
      input.value = '';
      answer(text);
    });
  })();
</script>
